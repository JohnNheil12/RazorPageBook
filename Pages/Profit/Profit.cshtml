@* Profit.cshtml - DISPLAY ONLY (demo data connected to Orders) *@
@page "/Profit/Profit"
@{
    Layout = null;
    if (Request.Query["partial"] != "true") {
        Response.Redirect("/Dashboard");
        return;
    }
}

<div class="prf-page" style="padding: 28px;">

    <div class="prf-page-header">
        <div class="header-left">
            <div class="prf-eyebrow"><span class="prf-eyebrow-dot"></span> Revenue Analytics</div>
            <h1 class="prf-title">Profit <span class="prf-title-accent">Overview</span></h1>
            <p class="prf-subtitle">Track revenue, best sellers, and order performance</p>
        </div>
        <div class="header-right">
            <button class="prf-btn-ghost"><i class="bi bi-download"></i> Export Report</button>
        </div>
    </div>

    <!-- Stats (driven by JS from shared demo data) -->
    <div class="prf-stats-grid">
        <div class="prf-stat">
            <div class="prf-stat-icon green"><i class="bi bi-cash-stack"></i></div>
            <div class="prf-stat-body">
                <span class="prf-stat-val" id="pTotalRevenue">₱ 0</span>
                <span class="prf-stat-lbl">Total Revenue</span>
            </div>
            <div class="prf-stat-trend"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="prf-stat">
            <div class="prf-stat-icon blue"><i class="bi bi-bag-check"></i></div>
            <div class="prf-stat-body">
                <span class="prf-stat-val" id="pTotalOrders">0</span>
                <span class="prf-stat-lbl">Orders Fulfilled</span>
            </div>
            <div class="prf-stat-trend"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="prf-stat">
            <div class="prf-stat-icon violet"><i class="bi bi-graph-up"></i></div>
            <div class="prf-stat-body">
                <span class="prf-stat-val" id="pAvgOrder">₱ 0</span>
                <span class="prf-stat-lbl">Avg. Order Value</span>
            </div>
            <div class="prf-stat-trend"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="prf-stat">
            <div class="prf-stat-icon amber"><i class="bi bi-book"></i></div>
            <div class="prf-stat-body">
                <span class="prf-stat-val" id="pBooksSold">0</span>
                <span class="prf-stat-lbl">Books Sold</span>
            </div>
            <div class="prf-stat-trend"><i class="bi bi-arrow-up-right"></i></div>
        </div>
    </div>

    <!-- Bar Chart -->
    <div class="prf-chart-card">
        <div class="prf-chart-header">
            <div>
                <div class="prf-chart-title">Monthly Revenue</div>
                <div class="prf-chart-sub">Jan – Dec · All categories</div>
            </div>
            <span class="prf-growth-badge"><i class="bi bi-arrow-up-right"></i> +18.4% vs last year</span>
        </div>
        <div class="prf-bar-chart" id="prfBarChart">
            <!-- generated by JS -->
        </div>
    </div>

    <!-- This Month / This Week -->
    <div class="prf-split">
        <div class="prf-split-card">
            <div class="prf-split-lbl">This Month</div>
            <div class="prf-split-val" id="pThisMonth">₱ 0</div>
            <div class="prf-split-sub" id="pThisMonthOrders">From 0 completed orders</div>
            <span class="prf-trend-badge"><i class="bi bi-arrow-up-right"></i> +12% vs last month</span>
        </div>
        <div class="prf-split-card">
            <div class="prf-split-lbl">This Week</div>
            <div class="prf-split-val" id="pThisWeek">₱ 0</div>
            <div class="prf-split-sub" id="pThisWeekOrders">From 0 completed orders</div>
            <span class="prf-trend-badge"><i class="bi bi-arrow-up-right"></i> +7% vs last week</span>
        </div>
    </div>

    <!-- Best Sellers -->
    <div class="prf-bestsellers">
        <div class="prf-bs-header">
            <i class="bi bi-trophy" style="color:#d97706;"></i>
            <span>Best Selling Books</span>
        </div>
        <div id="prfBestSellers">
            <!-- generated by JS -->
        </div>
    </div>
</div>

<style>
    .prf-page {
        --ps: #ffffff; --pb: #f8fafc; --pbr: #e2e8f0; --pbrl: #f1f5f9;
        --pt: #0f172a; --ptm: #64748b; --ptl: #94a3b8;
        --pa: #1d4ed8;
        --pe: #059669; --pebg: #ecfdf5; --pebr: #a7f3d0;
        --pam: #d97706; --pambg: #fffbeb;
        --pbl: #2563eb; --pblbg: #eff6ff;
        --pv: #7c3aed; --pvbg: #f5f3ff;
        --pg: #16a34a; --pgbg: #f0fdf4;
        --pi: #4f46e5; --pibg: #eef2ff; --pibr: #c7d2fe;
    }

    .prf-page-header { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding: 28px 32px; margin-bottom: 24px; background: var(--ps); border: 1px solid var(--pbr); border-radius: 16px; border-left: 4px solid var(--pa); box-shadow: 0 1px 6px rgba(15,23,42,0.05); }
    .prf-eyebrow { display: flex; align-items: center; gap: 7px; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.6px; color: var(--pa); margin-bottom: 6px; }
    .prf-eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--pa); display: inline-block; }
    .prf-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--pt); letter-spacing: -0.5px; margin: 0 0 4px; line-height: 1.15; }
    .prf-title-accent { color: var(--pa); font-style: italic; }
    .prf-subtitle { font-size: 0.84rem; color: var(--ptm); margin: 0; }
    .prf-btn-ghost { display: inline-flex; align-items: center; gap: 7px; padding: 10px 18px; background: var(--ps); color: var(--pt); border: 1.5px solid var(--pbr); border-radius: 10px; font-size: 0.84rem; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: background 0.15s; }
    .prf-btn-ghost:hover { background: #f1f5f9; }

    /* Stats */
    .prf-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 20px; }
    .prf-stat { background: var(--ps); border: 1px solid var(--pbr); border-radius: 14px; padding: 18px 20px; display: flex; align-items: center; gap: 14px; position: relative; overflow: hidden; transition: box-shadow 0.18s, transform 0.18s; }
    .prf-stat:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,23,42,0.08); }
    .prf-stat::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .prf-stat:nth-child(1)::before { background: var(--pg); }
    .prf-stat:nth-child(2)::before { background: var(--pbl); }
    .prf-stat:nth-child(3)::before { background: var(--pv); }
    .prf-stat:nth-child(4)::before { background: var(--pam); }
    .prf-stat-icon { width: 44px; height: 44px; border-radius: 11px; display: flex; align-items: center; justify-content: center; font-size: 1.15rem; flex-shrink: 0; }
    .prf-stat-icon.green  { background: var(--pgbg); color: var(--pg); }
    .prf-stat-icon.blue   { background: var(--pblbg); color: var(--pbl); }
    .prf-stat-icon.violet { background: var(--pvbg);  color: var(--pv); }
    .prf-stat-icon.amber  { background: var(--pambg); color: var(--pam); }
    .prf-stat-body { flex: 1; display: flex; flex-direction: column; line-height: 1.2; }
    .prf-stat-val { font-size: 1.5rem; font-weight: 700; color: var(--pt); letter-spacing: -0.5px; }
    .prf-stat-lbl { font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--ptm); margin-top: 2px; }
    .prf-stat-trend { width: 26px; height: 26px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; background: var(--pebg); color: var(--pe); flex-shrink: 0; }

    /* Chart */
    .prf-chart-card { background: var(--ps); border: 1px solid var(--pbr); border-radius: 16px; padding: 24px 28px; margin-bottom: 20px; }
    .prf-chart-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 24px; gap: 12px; flex-wrap: wrap; }
    .prf-chart-title { font-size: 1rem; font-weight: 700; color: var(--pt); margin-bottom: 3px; }
    .prf-chart-sub { font-size: 0.78rem; color: var(--ptm); }
    .prf-growth-badge { display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; border-radius: 20px; background: var(--pebg); color: var(--pe); border: 1px solid var(--pebr); font-size: 0.75rem; font-weight: 700; }
    .prf-bar-chart { display: flex; align-items: flex-end; gap: 8px; height: 180px; padding-bottom: 28px; position: relative; }
    .prf-bar-chart::after { content: ''; position: absolute; bottom: 28px; left: 0; right: 0; height: 1px; background: var(--pbrl); }
    .prf-bar-group { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .prf-bar { width: 100%; border-radius: 6px 6px 0 0; background: var(--pibg); border: 1px solid var(--pibr); cursor: pointer; min-height: 4px; transition: background 0.2s; }
    .prf-bar:hover { background: var(--pa); border-color: var(--pa); }
    .prf-bar.highlight { background: var(--pa); border-color: #1e40af; box-shadow: 0 4px 14px rgba(29,78,216,0.25); }
    .prf-bar-lbl { font-size: 0.63rem; font-weight: 600; color: var(--ptm); text-transform: uppercase; }

    /* Split */
    .prf-split { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 20px; }
    .prf-split-card { background: var(--ps); border: 1px solid var(--pbr); border-radius: 14px; padding: 22px 24px; }
    .prf-split-lbl { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--ptm); margin-bottom: 6px; }
    .prf-split-val { font-family: 'Playfair Display', serif; font-size: 1.9rem; font-weight: 700; color: var(--pt); margin-bottom: 4px; }
    .prf-split-sub { font-size: 0.78rem; color: var(--ptm); margin-bottom: 10px; }
    .prf-trend-badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; background: var(--pebg); color: var(--pe); border: 1px solid var(--pebr); font-size: 0.72rem; font-weight: 700; }

    /* Best sellers */
    .prf-bestsellers { background: var(--ps); border: 1px solid var(--pbr); border-radius: 16px; overflow: hidden; }
    .prf-bs-header { padding: 16px 22px; border-bottom: 1px solid var(--pbr); display: flex; align-items: center; gap: 8px; font-size: 0.95rem; font-weight: 700; color: var(--pt); }
    .prf-bs-row { display: flex; align-items: center; gap: 16px; padding: 13px 22px; border-bottom: 1px solid var(--pbrl); transition: background 0.12s; }
    .prf-bs-row:last-child { border-bottom: none; }
    .prf-bs-row:hover { background: #fafbfc; }
    .prf-bs-rank { width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; flex-shrink: 0; background: var(--pbrl); color: var(--ptm); }
    .prf-bs-rank.gold   { background: #fef9c3; color: #a16207; border: 1px solid #fde047; }
    .prf-bs-rank.silver { background: #f1f5f9; color: #475569; border: 1px solid #cbd5e1; }
    .prf-bs-rank.bronze { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
    .prf-bs-info { flex: 1; min-width: 0; }
    .prf-bs-title { font-size: 0.875rem; font-weight: 600; color: var(--pt); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .prf-bs-author { font-size: 0.75rem; color: var(--ptm); }
    .prf-bs-meta { text-align: right; flex-shrink: 0; }
    .prf-bs-qty { font-size: 0.75rem; color: var(--ptm); }
    .prf-bs-amount { font-size: 0.9rem; font-weight: 700; color: var(--pt); }

    @@media (max-width: 1024px) { .prf-stats-grid { grid-template-columns: repeat(2, 1fr); } .prf-split { grid-template-columns: 1fr; } }
    @@media (max-width: 640px) {
        .prf-page { padding: 16px !important; }
        .prf-stats-grid { grid-template-columns: 1fr 1fr; }
        .prf-page-header { flex-direction: column; align-items: flex-start; padding: 20px !important; }
    }
</style>

<script>
    // ── Shared demo data (same orders as Orders.cshtml) ──
    const prfOrders = [
        { month: 1,  status: "Completed", total: 1495.60, items: 2 },
        { month: 2,  status: "Processing", total: 1189.60, items: 2 },
        { month: 3,  status: "Pending",   total: 1725.60, items: 3 },
        { month: 3,  status: "Shipped",   total: 2352.00, items: 2 },
        { month: 3,  status: "Completed", total: 1064.00, items: 2 },
        { month: 3,  status: "Pending",   total: 1884.00, items: 3 },
        { month: 3,  status: "Completed", total: 705.60,  items: 2 },
        { month: 3,  status: "Pending",   total: 2016.00, items: 3 },
    ];

    const bestSellersData = [
        { title: "Harry Potter and the Sorcerer's Stone", author: "J.K. Rowling",        sold: 3, revenue: 2250.00 },
        { title: "The Lord of the Rings",                author: "J.R.R. Tolkien",       sold: 2, revenue: 2400.00 },
        { title: "Dune",                                 author: "Frank Herbert",         sold: 2, revenue: 1800.00 },
        { title: "Atomic Habits",                        author: "James Clear",           sold: 2, revenue: 1100.00 },
        { title: "Rich Dad Poor Dad",                    author: "Robert Kiyosaki",       sold: 2, revenue: 960.00  },
    ];

    const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    // Simulated monthly revenue (real months + forecasted)
    const monthlyRevenue = [4200, 3800, 12432.80, 0, 0, 0, 0, 0, 0, 0, 0, 0];

    function fmt(n) { return '₱ ' + n.toLocaleString('en-PH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }); }

    function initProfit() {
        const completed = prfOrders.filter(o => o.status === "Completed");
        const totalRevenue = prfOrders.reduce((s, o) => s + o.total, 0);
        const totalOrders = completed.length;
        const avgOrder = totalOrders > 0 ? totalRevenue / prfOrders.length : 0;
        const totalBooks = prfOrders.reduce((s, o) => s + o.items, 0);

        // This month (March = month 3)
        const thisMonthOrds = prfOrders.filter(o => o.month === 3);
        const thisMonthRev = thisMonthOrds.reduce((s, o) => s + o.total, 0);
        const thisMonthCompleted = thisMonthOrds.filter(o => o.status === "Completed").length;

        // This week (last 2 orders as demo)
        const thisWeekOrds = prfOrders.slice(-2);
        const thisWeekRev = thisWeekOrds.reduce((s, o) => s + o.total, 0);
        const thisWeekCompleted = thisWeekOrds.filter(o => o.status === "Completed").length;

        document.getElementById('pTotalRevenue').textContent = fmt(totalRevenue);
        document.getElementById('pTotalOrders').textContent = totalOrders;
        document.getElementById('pAvgOrder').textContent = fmt(avgOrder);
        document.getElementById('pBooksSold').textContent = totalBooks;

        document.getElementById('pThisMonth').textContent = fmt(thisMonthRev);
        document.getElementById('pThisMonthOrders').textContent = `From ${thisMonthCompleted} completed orders`;
        document.getElementById('pThisWeek').textContent = fmt(thisWeekRev);
        document.getElementById('pThisWeekOrders').textContent = `From ${thisWeekCompleted} completed orders`;

        // Bar chart
        const maxRev = Math.max(...monthlyRevenue.filter(v => v > 0));
        const barChart = document.getElementById('prfBarChart');
        barChart.innerHTML = monthlyRevenue.map((rev, i) => {
            const pct = maxRev > 0 ? Math.max((rev / maxRev) * 100, rev > 0 ? 8 : 2) : 2;
            const isHigh = rev === maxRev;
            return `
                <div class="prf-bar-group">
                    <div class="prf-bar ${isHigh ? 'highlight' : ''}" style="height:${pct}%"
                         title="${rev > 0 ? fmt(rev) : 'No data'}"></div>
                    <div class="prf-bar-lbl">${months[i]}</div>
                </div>`;
        }).join('');

        // Best sellers
        const rankClass = (i) => i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '';
        document.getElementById('prfBestSellers').innerHTML = bestSellersData.map((b, i) => `
            <div class="prf-bs-row">
                <div class="prf-bs-rank ${rankClass(i)}">${i + 1}</div>
                <div class="prf-bs-info">
                    <div class="prf-bs-title">${b.title}</div>
                    <div class="prf-bs-author">${b.author}</div>
                </div>
                <div class="prf-bs-meta">
                    <div class="prf-bs-qty">${b.sold} sold</div>
                    <div class="prf-bs-amount">₱ ${b.revenue.toLocaleString('en-PH', {minimumFractionDigits:2})}</div>
                </div>
            </div>
        `).join('');
    }

    initProfit();
</script>
