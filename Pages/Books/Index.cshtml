@page
@model RazorPageBooks.Pages.Books.IndexModel

@{
    ViewData["Title"] = "Index";
}


<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end border-bottom pb-3 mb-4">
        <div>
            <h1 class="display-4 fw-bold text-serif" style="color: #2c3e50;">The Book Cellar.</h1>
            <p class="text-muted mb-0">Curating and managing your literary collection.</p>
        </div>
        <a asp-page="Create" class="btn btn-dark btn-lg shadow-sm">
            <i class="bi bi-plus-lg"></i> Add New Book
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Title</th>
                            <th>Author</th>
                            <th>Year Published</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Book)
                        {
                            <tr class="align-middle">
                                <td class="ps-4 fw-bold">@item.Title</td>
                                <td>@item.Author</td>
                                <td>@item.YearPublished</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                                        <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">View</a>
                                        <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .text-serif {
        font-family: 'Playfair Display', serif;
    }

    .table-hover tbody tr:hover {
        background-color: #f1f4f9;
        transition: 0.3s;
    }
</style>