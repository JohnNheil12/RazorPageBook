@page
@model RazorPageBooks.Pages.Books.EditModel

@{
    ViewData["Title"] = "Edit Book";
}
 <link rel="stylesheet" href="~/css/edit.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<div class="page-wrapper">

    <!-- Page Header -->
    <div class="page-header">
        <div class="text-center">
            <h1 class="page-title">Edit Entry.</h1>
            <p class="page-subtitle">Modify the details of the book entry.</p>
        </div>
        <a asp-page="Index" class="back-btn">
            <i class="bi bi-arrow-left"></i> Back to Library
        </a>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        <div class="card-accent"></div>

        <div class="card-inner">
            <form method="post" class="book-form">
                <div asp-validation-summary="ModelOnly" class="validation-alert"></div>
                <input type="hidden" asp-for="Book.Id" />

                <div class="form-row two-col">
                    <div class="field-group">
                        <label asp-for="Book.Title" class="field-label">
                            <i class="bi bi-book"></i> Book Title
                        </label>
                        <input asp-for="Book.Title" class="field-input"
                               placeholder="e.g. The Great Gatsby" autocomplete="off" />
                        <span asp-validation-for="Book.Title" class="field-error"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Book.Author" class="field-label">
                            <i class="bi bi-person"></i> Author Name
                        </label>
                        <input asp-for="Book.Author" class="field-input"
                               placeholder="e.g. F. Scott Fitzgerald" autocomplete="off" />
                        <span asp-validation-for="Book.Author" class="field-error"></span>
                    </div>
                </div>

                <div class="form-row two-col">
                    <div class="field-group">
                        <label asp-for="Book.YearPublished" class="field-label">
                            <i class="bi bi-calendar3"></i> Year Published
                        </label>
                        <input asp-for="Book.YearPublished" class="field-input"
                               placeholder="YYYY" autocomplete="off" />
                        <span asp-validation-for="Book.YearPublished" class="field-error"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Book.Publisher" class="field-label">
                            <i class="bi bi-building"></i> Publisher
                        </label>
                        <input asp-for="Book.Publisher" class="field-input"
                               placeholder="Publishing House Name" autocomplete="off" />
                        <span asp-validation-for="Book.Publisher" class="field-error"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="field-group">
                        <label asp-for="Book.ImageUrl" class="field-label">
                            <i class="bi bi-image"></i> Cover Image URL
                        </label>
                        <div class="url-field-wrap">
                            <input asp-for="Book.ImageUrl" class="field-input"
                                   placeholder="https://example.com/cover.jpg" autocomplete="off"
                                   id="imageUrlInput" />
                            <div class="cover-preview" id="coverPreview">
                                <img id="previewImg"
                                     src="@(string.IsNullOrEmpty(Model.Book.ImageUrl) ? "" : Model.Book.ImageUrl)"
                                     alt=""
                                     style="@(string.IsNullOrEmpty(Model.Book.ImageUrl) ? "display:none" : "display:block")" />
                                <span class="preview-placeholder"
                                      style="@(string.IsNullOrEmpty(Model.Book.ImageUrl) ? "" : "display:none")">
                                    <i class="bi bi-image"></i>
                                </span>
                            </div>
                        </div>
                        <span asp-validation-for="Book.ImageUrl" class="field-error"></span>
                    </div>
                </div>

                <!-- Centered Buttons -->
                <div class="form-actions">
                    <button type="submit" class="btn-save">
                        <i class="bi bi-check-lg"></i> Update Changes
                    </button>
                    <a asp-page="./Index" class="btn-cancel">← Discard and Return</a>
                </div>

            </form>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        const input = document.getElementById('imageUrlInput');
        const img = document.getElementById('previewImg');
        const placeholder = document.querySelector('.preview-placeholder');

        input.addEventListener('input', function () {
            const url = this.value.trim();
            if (url) {
                img.src = url;
                img.style.display = 'block';
                placeholder.style.display = 'none';
                img.onerror = () => {
                    img.style.display = 'none';
                    placeholder.style.display = 'flex';
                };
            } else {
                img.style.display = 'none';
                placeholder.style.display = 'flex';
            }
        });
    </script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}