@page
@model RazorPageBooks.Pages.Books.EditModel

@{
    ViewData["Title"] = "Edit Book";
}

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg p-4 create-card">
        <h2 class="text-center mb-1">Edit Book</h2>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Book.Id" />

            <!-- Title -->
            <div class="form-group mb-3">
                <label asp-for="Book.Title" class="form-label"></label>
                <input asp-for="Book.Title" class="form-control" />
                <span asp-validation-for="Book.Title" class="text-danger"></span>
            </div>

            <!-- Author -->
            <div class="form-group mb-3">
                <label asp-for="Book.Author" class="form-label"></label>
                <input asp-for="Book.Author" class="form-control" />
                <span asp-validation-for="Book.Author" class="text-danger"></span>
            </div>

            <!-- Year Published -->
            <div class="form-group mb-4">
                <label asp-for="Book.YearPublished" class="form-label"></label>
                <input asp-for="Book.YearPublished" class="form-control" />
                <span asp-validation-for="Book.YearPublished" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Book.Publisher" class="form-label"></label>
                <input asp-for="Book.Publisher" class="form-control" />
                <span asp-validation-for="Book.Publisher" class="text-danger"></span>
            </div>

            <!-- Save Button -->
            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary btn-lg">
                    Save
                </button>
            </div>
        </form>

        <!-- Back to List Link -->
        <div class="text-center">
            <a asp-page="./Index" class="text-decoration-none">
                ← Back to List
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
