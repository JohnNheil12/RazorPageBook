﻿@* Products.cshtml *@
@page "/Books/Products"
@model RazorPageBooks.Pages.Books.IndexModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    Layout = null;
    if (Request.Query["partial"] != "true") {
        Response.Redirect("/Dashboard");
        return;
    }
}

<div class="products-page">

    @* --- Header --- *@
    <div class="admin-page-header">
        <div class="header-left">
            <div class="page-eyebrow"><span class="eyebrow-dot"></span> Book Management</div>
            <h1 class="page-title">The Book <span class="title-accent">Cellar</span></h1>
            <p class="page-subtitle">Manage and oversee your entire book collection</p>
        </div>
        <div class="header-right">
            @if (SignInManager.IsSignedIn(User))
            {
                <button class="btn-add-book" onclick="loadContent('/Books/Create?partial=true')">
                    <i class="bi bi-plus-lg"></i>
                    <span>Add New Book</span>
                </button>
            }
        </div>
    </div>

    @* --- Stats --- *@
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon indigo"><i class="bi bi-journals"></i></div>
            <div class="stat-body">
                <span class="stat-value">@Model.Book.Count()</span>
                <span class="stat-label">Total Books</span>
            </div>
            <div class="stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon emerald"><i class="bi bi-pen"></i></div>
            <div class="stat-body">
                <span class="stat-value">@Model.Book.Select(b => b.Author).Distinct().Count()</span>
                <span class="stat-label">Authors</span>
            </div>
            <div class="stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon amber"><i class="bi bi-building"></i></div>
            <div class="stat-body">
                <span class="stat-value">@Model.Book.Select(b => b.Publisher).Distinct().Count()</span>
                <span class="stat-label">Publishers</span>
            </div>
            <div class="stat-trend neutral"><i class="bi bi-dash"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon rose"><i class="bi bi-calendar3"></i></div>
            <div class="stat-body">
                <span class="stat-value">@(Model.Book.Any() ? Model.Book.Max(b => b.YearPublished) : 0)</span>
                <span class="stat-label">Latest Year</span>
            </div>
            <div class="stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
    </div>

    @* --- Toolbar / Live Search --- *@
    <div class="admin-toolbar">
        <form method="get"
              action="/Books/Products"
              class="search-form"
              onsubmit="handleSearch(event, this)">
            <input type="hidden" name="partial" value="true" />
            <div class="search-box">
                <i class="bi bi-search search-ico" id="searchIco"></i>
                <input type="text"
                       id="liveSearchInput"
                       name="SearchString"
                       value="@Model.SearchString"
                       class="search-input"
                       placeholder="Search title, author, year..."
                       autocomplete="off" />
                <button type="button" class="search-clear-x" id="searchClearX"
                        onclick="clearLiveSearch()"
                        style="display:@(!string.IsNullOrEmpty(Model.SearchString) ? "flex" : "none")">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </form>
        <div class="toolbar-meta" id="liveSearchMeta" style="display:@(!string.IsNullOrEmpty(Model.SearchString) ? "flex" : "none")">
            <span id="liveSearchCount" class="search-count-badge">
                <i class="bi bi-funnel-fill"></i>
                <span id="liveSearchCountNum">@Model.Book.Count()</span> result@(Model.Book.Count() == 1 ? "" : "s")
            </span>
        </div>
    </div>

    @* Live search dropdown *@
    <div class="live-dropdown" id="liveDropdown"></div>

    @* --- Table --- *@
    <div class="admin-table-card">
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th class="th-cover">Cover</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Author</th>
                        <th class="center">Year</th>
                        <th>Publisher</th>
                        <th class="center">Price</th>
                        <th class="right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Book.Any())
                    {
                        <tr>
                            <td colspan="8" class="empty-state">
                                <i class="bi bi-search"></i>
                                <span>No books found matching your criteria.</span>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Book)
                    {
                        <tr class="book-row">
                            <td class="td-cover">
                                <div class="book-thumb">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/48x68?text=?" : item.ImageUrl)"
                                         alt="Cover"
                                         onerror="this.src='https://via.placeholder.com/48x68?text=?'" />
                                </div>
                            </td>
                            <td><div class="book-title-text">@item.Title</div></td>
                            <td><span class="category-pill">@item.Category</span></td>
                            <td>
                                <div class="author-chip">
                                    <div class="author-initial">@(item.Author?[0].ToString().ToUpper() ?? "?")</div>
                                    <span class="author-name-text">@item.Author</span>
                                </div>
                            </td>
                            <td class="center"><span class="year-pill">@item.YearPublished</span></td>
                            <td><span class="pub-text">@item.Publisher</span></td>
                            <td class="center"><span class="price-text">₱@(item.Price?.ToString("N2") ?? "0.00")</span></td>
                            <td class="right">
                                <div class="action-cluster">
                                    <button type="button"
                                            class="act-btn act-view"
                                            title="View Details"
                                            onclick="loadContent('/Books/Details?id=@item.Id&partial=true')">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @if (SignInManager.IsSignedIn(User))
                                    {
                                        <button type="button"
                                                class="act-btn act-edit"
                                                title="Edit"
                                                onclick="loadContent('/Books/Edit?id=@item.Id&partial=true')">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (User.IsInRole("Admin"))
                                        {
                                        <button type="button"
                                                class="act-btn act-delete"
                                                title="Delete"
                                                onclick="loadContent('/Books/Delete?id=@item.Id&partial=true')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .products-page {
        padding: 28px;
        --surface: #ffffff;
        --bg: #f8fafc;
        --border: #e2e8f0;
        --txt: #0f172a;
        --txt-muted: #64748b;
        --accent: #1d4ed8;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    /* Header */
    .admin-page-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 24px 32px; margin-bottom: 24px;
        background: var(--surface); border: 1px solid var(--border); border-radius: 16px;
        border-left: 4px solid var(--accent); box-shadow: 0 1px 4px rgba(0,0,0,0.03);
    }
    .page-eyebrow {
        font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--accent);
        display: flex; align-items: center; gap: 6px; margin-bottom: 4px;
    }
    .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); display: inline-block; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; margin: 0; color: var(--txt); }
    .title-accent { color: var(--accent); font-style: italic; }
    .page-subtitle { font-size: 0.82rem; color: var(--txt-muted); margin: 2px 0 0; }

    .btn-add-book {
        background: var(--accent); color: #fff;
        padding: 11px 22px; border-radius: 12px; border: none;
        font-weight: 600; font-size: 0.88rem;
        display: flex; align-items: center; gap: 8px;
        box-shadow: 0 4px 15px rgba(37,99,235,0.28);
        cursor: pointer; transition: all 0.2s; font-family: inherit;
    }
    .btn-add-book:hover { background: #1d4ed8; transform: scale(1.02); box-shadow: 0 6px 20px rgba(37,99,235,0.38); }

    /* Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .stat-card {
        background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
        padding: 16px; display: flex; align-items: center; gap: 12px;
    }
    .stat-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
    .stat-icon.indigo { background: #eef2ff; color: #4f46e5; }
    .stat-icon.emerald { background: #ecfdf5; color: #059669; }
    .stat-icon.amber { background: #fffbeb; color: #d97706; }
    .stat-icon.rose { background: #fff1f2; color: #e11d48; }
    .stat-body { flex: 1; }
    .stat-value { font-size: 1.3rem; font-weight: 700; display: block; color: var(--txt); }
    .stat-label { font-size: 0.65rem; text-transform: uppercase; color: var(--txt-muted); font-weight: 600; }
    .stat-trend { font-size: 0.8rem; color: #64748b; }
    .stat-trend.up { color: #059669; }

    /* Toolbar */
    .admin-toolbar {
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px; margin-bottom: 16px; position: relative;
    }
    .search-form { flex: 1; max-width: 420px; position: relative; }
    .search-box {
        display: flex; align-items: center; background: white;
        border: 1.5px solid var(--border); border-radius: 10px; padding: 4px 6px 4px 14px;
        gap: 8px; transition: border-color 0.18s, box-shadow 0.18s;
    }
    .search-box:focus-within {
        border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }
    .search-ico { color: #94a3b8; font-size: 0.88rem; flex-shrink: 0; transition: color 0.15s; }
    .search-box:focus-within .search-ico { color: #2563eb; }
    .search-input { flex: 1; border: none; outline: none; font-size: 0.85rem; padding: 8px 4px; font-family: inherit; background: transparent; }
    .search-clear-x {
        background: none; border: none; cursor: pointer; color: #94a3b8;
        width: 28px; height: 28px; border-radius: 6px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.75rem; transition: all 0.15s;
    }
    .search-clear-x:hover { background: #f1f5f9; color: #e11d48; }
    .search-count-badge {
        display: inline-flex; align-items: center; gap: 5px;
        background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe;
        padding: 4px 12px; border-radius: 20px; font-size: 0.76rem; font-weight: 600;
    }

    /* Live search dropdown */
    .live-dropdown {
        position: absolute; left: 28px; right: 28px; top: auto;
        background: white; border: 1px solid var(--border); border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.10); z-index: 999;
        max-height: 360px; overflow-y: auto; display: none;
        margin-top: -12px; margin-bottom: 8px;
    }
    .live-dropdown.open { display: block; }
    .live-item {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 14px; cursor: pointer; transition: background 0.12s;
        border-bottom: 1px solid #f1f5f9;
    }
    .live-item:last-child { border-bottom: none; }
    .live-item:hover { background: #f8fafc; }
    .live-item-thumb {
        width: 32px; height: 44px; border-radius: 4px; overflow: hidden;
        border: 1px solid #e2e8f0; flex-shrink: 0;
    }
    .live-item-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .live-item-body { flex: 1; min-width: 0; }
    .live-item-title { font-size: 0.84rem; font-weight: 600; color: #0f172a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .live-item-meta { font-size: 0.73rem; color: #64748b; margin-top: 2px; }
    .live-item-year { background: #f1f5f9; color: #475569; padding: 2px 8px; border-radius: 10px; font-size: 0.71rem; font-weight: 600; flex-shrink: 0; }
    .live-empty { padding: 20px; text-align: center; color: #94a3b8; font-size: 0.84rem; }
    .live-footer {
        padding: 9px 14px; text-align: center; border-top: 1px solid #f1f5f9;
        font-size: 0.78rem; color: #2563eb; cursor: pointer; font-weight: 600;
        transition: background 0.12s;
    }
    .live-footer:hover { background: #f8fafc; }
    .live-searching { padding: 16px; text-align: center; color: #94a3b8; font-size: 0.84rem; display: flex; align-items: center; justify-content: center; gap: 8px; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .spin-icon { display: inline-block; animation: spin 0.7s linear infinite; }

    /* Table */
    .admin-table-card { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .table-responsive { overflow-x: auto; }
    .admin-table { width: 100%; border-collapse: collapse; min-width: 620px; }
    .admin-table th {
        background: #f8fafc; padding: 12px 16px; text-align: left;
        font-size: 0.68rem; color: #64748b; text-transform: uppercase;
        letter-spacing: 0.07em; font-weight: 700; border-bottom: 1px solid var(--border);
    }
    .admin-table td { padding: 12px 16px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    .admin-table tr:last-child td { border-bottom: none; }
    .book-row { transition: background 0.15s; }
    .book-row:hover { background: #fafafa; }

    .book-thumb { width: 40px; height: 56px; border-radius: 5px; overflow: hidden; border: 1px solid #e2e8f0; flex-shrink: 0; }
    .book-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .book-title-text { font-weight: 600; color: #1e293b; font-size: 0.88rem; line-height: 1.3; }

    .author-chip { display: flex; align-items: center; gap: 8px; }
    .author-initial {
        width: 26px; height: 26px; border-radius: 50%;
        background: #eef2ff; color: #4f46e5;
        font-size: 0.65rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .author-name-text { font-size: 0.85rem; color: #334155; }

    .year-pill { background: #f1f5f9; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; color: #475569; }
    .pub-text { font-size: 0.84rem; color: #64748b; }

    .category-pill { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; padding: 3px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; white-space: nowrap; }
    .price-text { font-size: 0.84rem; font-weight: 700; color: #0f172a; }

    /* Action buttons — FIXED: border:none + cursor:pointer */
    .action-cluster { display: flex; gap: 5px; justify-content: flex-end; }
    .act-btn {
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 7px; font-size: 0.82rem;
        border: none;           /* removes default button border */
        cursor: pointer;        /* makes it obviously clickable */
        transition: all 0.15s;
        padding: 0;
        background: transparent;
    }
    .act-btn:hover { transform: scale(1.12); }
    .act-view  { background: #eff6ff !important; color: #2563eb !important; }
    .act-edit  { background: #f0fdf4 !important; color: #16a34a !important; }
    .act-delete{ background: #fef2f2 !important; color: #dc2626 !important; }
    .act-view:hover  { background: #dbeafe !important; }
    .act-edit:hover  { background: #dcfce7 !important; }
    .act-delete:hover{ background: #fee2e2 !important; }

    /* Empty state */
    .empty-state { padding: 60px 0; text-align: center; color: #94a3b8; }
    .empty-state i { font-size: 2rem; display: block; margin-bottom: 10px; }

    .center { text-align: center !important; }
    .right  { text-align: right  !important; }
</style>

<script>
    /* ── Live Search ── */
    (function () {
        const input    = document.getElementById('liveSearchInput');
        const dropdown = document.getElementById('liveDropdown');
        const clearX   = document.getElementById('searchClearX');
        const meta     = document.getElementById('liveSearchMeta');
        const countNum = document.getElementById('liveSearchCountNum');

        if (!input) return;

        let debounceTimer = null;
        let currentQuery  = '';

        // Fetch suggestions from the server's OnGetSearchAsync handler
        async function fetchSuggestions(q) {
            try {
                const res  = await fetch(`/Books/Products?handler=Search&searchString=${encodeURIComponent(q)}&partial=true`);
                const data = await res.json();
                return data;
            } catch { return null; }
        }

        // Highlight matching text
        function highlight(text, q) {
            if (!q) return text;
            const escaped = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            return text.replace(new RegExp(`(${escaped})`, 'gi'),
                '<mark style="background:#dbeafe;color:#1d4ed8;border-radius:3px;padding:0 1px">$1</mark>');
        }

        function showDropdown(results, q) {
            dropdown.innerHTML = '';
            if (results === null) {
                dropdown.innerHTML = `<div class="live-empty"><i class="bi bi-wifi-off"></i> Could not fetch results</div>`;
            } else if (results.length === 0) {
                dropdown.innerHTML = `<div class="live-empty"><i class="bi bi-search" style="display:block;font-size:1.5rem;margin-bottom:6px;color:#cbd5e1"></i>No books match "<strong>${q}</strong>"</div>`;
            } else {
                results.forEach(b => {
                    const el = document.createElement('div');
                    el.className = 'live-item';
                    el.innerHTML = `
                        <div class="live-item-thumb">
                            <img src="https://via.placeholder.com/32x44?text=?" onerror="this.src='https://via.placeholder.com/32x44?text=?'" alt="">
                        </div>
                        <div class="live-item-body">
                            <div class="live-item-title">${highlight(b.title, q)}</div>
                            <div class="live-item-meta">${highlight(b.author, q)}</div>
                        </div>
                        <span class="live-item-year">${b.yearPublished}</span>`;
                    el.addEventListener('click', () => {
                        // Navigate to detail view
                        if (typeof loadContent === 'function') {
                            loadContent(`/Books/Details?id=${b.id}&partial=true`);
                        }
                        closeDropdown();
                    });
                    dropdown.appendChild(el);
                });

                // "Show all results" footer
                if (results.length >= 10) {
                    const footer = document.createElement('div');
                    footer.className = 'live-footer';
                    footer.innerHTML = `<i class="bi bi-list-ul"></i> Show all results for "<strong>${q}</strong>"`;
                    footer.addEventListener('click', () => { runFullSearch(q); closeDropdown(); });
                    dropdown.appendChild(footer);
                }
            }
            dropdown.classList.add('open');
        }

        function showLoading() {
            dropdown.innerHTML = `<div class="live-searching"><i class="bi bi-arrow-repeat spin-icon"></i> Searching…</div>`;
            dropdown.classList.add('open');
        }

        function closeDropdown() {
            dropdown.classList.remove('open');
            dropdown.innerHTML = '';
        }

        // Full page-content search (replaces the table via injectHTML)
        function runFullSearch(q) {
            const container = document.getElementById('pageContent');
            if (!container) return;
            const url = `/Books/Products?partial=true&SearchString=${encodeURIComponent(q)}`;
            fetch(url)
                .then(r => r.text())
                .then(html => {
                    if (typeof injectHTML === 'function') injectHTML(container, html);
                    else container.innerHTML = html;
                })
                .catch(() => { window.location.href = url; });
        }

        input.addEventListener('input', () => {
            const q = input.value.trim();
            clearX.style.display = q ? 'flex' : 'none';

            clearTimeout(debounceTimer);

            if (!q) {
                closeDropdown();
                meta.style.display = 'none';
                // Reset table to full list
                runFullSearch('');
                return;
            }

            if (q === currentQuery) return;
            currentQuery = q;
            showLoading();

            debounceTimer = setTimeout(async () => {
                const results = await fetchSuggestions(q);
                if (input.value.trim() !== q) return; // stale
                showDropdown(results, q);
                if (results && results.length > 0) {
                    meta.style.display = 'flex';
                    countNum.textContent = results.length;
                } else {
                    meta.style.display = 'none';
                }
                // Also update the table below with matching rows
                runFullSearch(q);
            }, 280);
        });

        // Close dropdown on Enter key → full search
        input.addEventListener('keydown', e => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const q = input.value.trim();
                closeDropdown();
                if (q) runFullSearch(q);
            }
            if (e.key === 'Escape') closeDropdown();
        });

        // Close on outside click
        document.addEventListener('click', e => {
            if (!dropdown.contains(e.target) && e.target !== input) closeDropdown();
        });

        window.clearLiveSearch = function () {
            input.value    = '';
            clearX.style.display = 'none';
            meta.style.display   = 'none';
            currentQuery = '';
            closeDropdown();
            runFullSearch('');
        };
    })();

    function handleSearch(event, formElement) {
        event.preventDefault();
        const q = document.getElementById('liveSearchInput')?.value.trim() || '';
        const url = `/Books/Products?partial=true&SearchString=${encodeURIComponent(q)}`;
        const container = document.getElementById('pageContent');
        if (container && typeof injectHTML === 'function') {
            fetch(url).then(r => r.text()).then(html => injectHTML(container, html))
                      .catch(() => { window.location.href = url; });
        } else {
            window.location.href = url;
        }
    }
</script>
