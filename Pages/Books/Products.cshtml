@* Products.cshtml *@
@page "/Books/Products"
@model RazorPageBooks.Pages.Books.IndexModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    Layout = null;
    if (Request.Query["partial"] != "true") {
        Response.Redirect("/Dashboard");
        return;
    }
}

<div class="products-page">

    @* --- Header --- *@
    <div class="admin-page-header">
        <div class="header-left">
            <div class="page-eyebrow"><span class="eyebrow-dot"></span> Book Management</div>
            <h1 class="page-title">The Book <span class="title-accent">Cellar</span></h1>
            <p class="page-subtitle">Manage and oversee your entire book collection</p>
        </div>
        <div class="header-right">
            @if (SignInManager.IsSignedIn(User))
            {
                <button class="btn-add-book" onclick="loadContent('/Books/Create?partial=true')">
                    <i class="bi bi-plus-lg"></i>
                    <span>Add New Book</span>
                </button>
            }
        </div>
    </div>

    @* --- Stats --- *@
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon indigo"><i class="bi bi-journals"></i></div>
            <div class="stat-body">
                <span class="stat-value">@Model.Book.Count()</span>
                <span class="stat-label">Total Books</span>
            </div>
            <div class="stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon emerald"><i class="bi bi-pen"></i></div>
            <div class="stat-body">
                <span class="stat-value">@Model.Book.Select(b => b.Author).Distinct().Count()</span>
                <span class="stat-label">Authors</span>
            </div>
            <div class="stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon amber"><i class="bi bi-building"></i></div>
            <div class="stat-body">
                <span class="stat-value">@Model.Book.Select(b => b.Publisher).Distinct().Count()</span>
                <span class="stat-label">Publishers</span>
            </div>
            <div class="stat-trend neutral"><i class="bi bi-dash"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon rose"><i class="bi bi-calendar3"></i></div>
            <div class="stat-body">
                <span class="stat-value">@(Model.Book.Any() ? Model.Book.Max(b => b.YearPublished) : 0)</span>
                <span class="stat-label">Latest Year</span>
            </div>
            <div class="stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
    </div>

    @* --- Toolbar / Search --- *@
    <div class="admin-toolbar">
        <form method="get"
              action="/Books/Products"
              class="search-form"
              onsubmit="handleSearch(event, this)">
            <input type="hidden" name="partial" value="true" />
            <div class="search-box">
                <i class="bi bi-search search-ico"></i>
                <input type="text"
                       name="SearchString"
                       value="@Model.SearchString"
                       class="search-input"
                       placeholder="Search title, author, year..."
                       autocomplete="off" />
                <button type="submit" class="search-btn">Search</button>
            </div>
        </form>
        @if (!string.IsNullOrEmpty(Model.SearchString))
        {
            <div class="toolbar-meta">
                <a href="#" onclick="clearSearch(event)" class="clear-search">
                    <i class="bi bi-x-circle"></i> Clear Results
                </a>
            </div>
        }
    </div>

    @* --- Table --- *@
    <div class="admin-table-card">
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th class="th-cover">Cover</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Author</th>
                        <th class="center">Year</th>
                        <th>Publisher</th>
                        <th class="center">Price</th>
                        <th class="right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Book.Any())
                    {
                        <tr>
                            <td colspan="8" class="empty-state">
                                <i class="bi bi-search"></i>
                                <span>No books found matching your criteria.</span>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Book)
                    {
                        <tr class="book-row">
                            <td class="td-cover">
                                <div class="book-thumb">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/48x68?text=?" : item.ImageUrl)"
                                         alt="Cover"
                                         onerror="this.src='https://via.placeholder.com/48x68?text=?'" />
                                </div>
                            </td>
                            <td><div class="book-title-text">@item.Title</div></td>
                            <td><span class="category-pill">@item.Category</span></td>
                            <td>
                                <div class="author-chip">
                                    <div class="author-initial">@(item.Author?[0].ToString().ToUpper() ?? "?")</div>
                                    <span class="author-name-text">@item.Author</span>
                                </div>
                            </td>
                            <td class="center"><span class="year-pill">@item.YearPublished</span></td>
                            <td><span class="pub-text">@item.Publisher</span></td>
                            <td class="center"><span class="price-text">₱@(item.Price?.ToString("N2") ?? "0.00")</span></td>
                            <td class="right">
                                <div class="action-cluster">
                                    <button type="button"
                                            class="act-btn act-view"
                                            title="View Details"
                                            onclick="loadContent('/Books/Details?id=@item.Id&partial=true')">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @if (SignInManager.IsSignedIn(User))
                                    {
                                        <button type="button"
                                                class="act-btn act-edit"
                                                title="Edit"
                                                onclick="loadContent('/Books/Edit?id=@item.Id&partial=true')">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (User.IsInRole("Admin"))
                                        {
                                        <button type="button"
                                                class="act-btn act-delete"
                                                title="Delete"
                                                onclick="loadContent('/Books/Delete?id=@item.Id&partial=true')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .products-page {
        padding: 28px;
        --surface: #ffffff;
        --bg: #f8fafc;
        --border: #e2e8f0;
        --txt: #0f172a;
        --txt-muted: #64748b;
        --accent: #1d4ed8;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    /* Header */
    .admin-page-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 24px 32px; margin-bottom: 24px;
        background: var(--surface); border: 1px solid var(--border); border-radius: 16px;
        border-left: 4px solid var(--accent); box-shadow: 0 1px 4px rgba(0,0,0,0.03);
    }
    .page-eyebrow {
        font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--accent);
        display: flex; align-items: center; gap: 6px; margin-bottom: 4px;
    }
    .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); display: inline-block; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; margin: 0; color: var(--txt); }
    .title-accent { color: var(--accent); font-style: italic; }
    .page-subtitle { font-size: 0.82rem; color: var(--txt-muted); margin: 2px 0 0; }

    .btn-add-book {
        background: var(--accent); color: #fff;
        padding: 11px 22px; border-radius: 12px; border: none;
        font-weight: 600; font-size: 0.88rem;
        display: flex; align-items: center; gap: 8px;
        box-shadow: 0 4px 15px rgba(37,99,235,0.28);
        cursor: pointer; transition: all 0.2s; font-family: inherit;
    }
    .btn-add-book:hover { background: #1d4ed8; transform: scale(1.02); box-shadow: 0 6px 20px rgba(37,99,235,0.38); }

    /* Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .stat-card {
        background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
        padding: 16px; display: flex; align-items: center; gap: 12px;
    }
    .stat-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
    .stat-icon.indigo { background: #eef2ff; color: #4f46e5; }
    .stat-icon.emerald { background: #ecfdf5; color: #059669; }
    .stat-icon.amber { background: #fffbeb; color: #d97706; }
    .stat-icon.rose { background: #fff1f2; color: #e11d48; }
    .stat-body { flex: 1; }
    .stat-value { font-size: 1.3rem; font-weight: 700; display: block; color: var(--txt); }
    .stat-label { font-size: 0.65rem; text-transform: uppercase; color: var(--txt-muted); font-weight: 600; }
    .stat-trend { font-size: 0.8rem; color: #64748b; }
    .stat-trend.up { color: #059669; }

    /* Toolbar */
    .admin-toolbar {
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px; margin-bottom: 16px;
    }
    .search-form { flex: 1; max-width: 420px; }
    .search-box {
        display: flex; align-items: center; background: white;
        border: 1px solid var(--border); border-radius: 10px; padding: 4px 6px 4px 14px;
        gap: 8px;
    }
    .search-ico { color: #94a3b8; font-size: 0.88rem; }
    .search-input { flex: 1; border: none; outline: none; font-size: 0.85rem; padding: 8px 4px; font-family: inherit; }
    .search-btn {
        background: var(--accent); color: white; border: none;
        padding: 7px 16px; border-radius: 8px; font-weight: 600;
        cursor: pointer; font-size: 0.82rem; font-family: inherit; transition: background 0.2s;
    }
    .search-btn:hover { background: #1d4ed8; }
    .clear-search { font-size: 0.82rem; color: #e11d48; text-decoration: none; display: flex; align-items: center; gap: 5px; }
    .clear-search:hover { color: #be123c; }

    /* Table */
    .admin-table-card { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .table-responsive { overflow-x: auto; }
    .admin-table { width: 100%; border-collapse: collapse; min-width: 620px; }
    .admin-table th {
        background: #f8fafc; padding: 12px 16px; text-align: left;
        font-size: 0.68rem; color: #64748b; text-transform: uppercase;
        letter-spacing: 0.07em; font-weight: 700; border-bottom: 1px solid var(--border);
    }
    .admin-table td { padding: 12px 16px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    .admin-table tr:last-child td { border-bottom: none; }
    .book-row { transition: background 0.15s; }
    .book-row:hover { background: #fafafa; }

    .book-thumb { width: 40px; height: 56px; border-radius: 5px; overflow: hidden; border: 1px solid #e2e8f0; flex-shrink: 0; }
    .book-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .book-title-text { font-weight: 600; color: #1e293b; font-size: 0.88rem; line-height: 1.3; }

    .author-chip { display: flex; align-items: center; gap: 8px; }
    .author-initial {
        width: 26px; height: 26px; border-radius: 50%;
        background: #eef2ff; color: #4f46e5;
        font-size: 0.65rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .author-name-text { font-size: 0.85rem; color: #334155; }

    .year-pill { background: #f1f5f9; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; color: #475569; }
    .pub-text { font-size: 0.84rem; color: #64748b; }

    .category-pill { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; padding: 3px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; white-space: nowrap; }
    .price-text { font-size: 0.84rem; font-weight: 700; color: #0f172a; }

    /* Action buttons — FIXED: border:none + cursor:pointer */
    .action-cluster { display: flex; gap: 5px; justify-content: flex-end; }
    .act-btn {
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 7px; font-size: 0.82rem;
        border: none;           /* removes default button border */
        cursor: pointer;        /* makes it obviously clickable */
        transition: all 0.15s;
        padding: 0;
        background: transparent;
    }
    .act-btn:hover { transform: scale(1.12); }
    .act-view  { background: #eff6ff !important; color: #2563eb !important; }
    .act-edit  { background: #f0fdf4 !important; color: #16a34a !important; }
    .act-delete{ background: #fef2f2 !important; color: #dc2626 !important; }
    .act-view:hover  { background: #dbeafe !important; }
    .act-edit:hover  { background: #dcfce7 !important; }
    .act-delete:hover{ background: #fee2e2 !important; }

    /* Empty state */
    .empty-state { padding: 60px 0; text-align: center; color: #94a3b8; }
    .empty-state i { font-size: 2rem; display: block; margin-bottom: 10px; }

    .center { text-align: center !important; }
    .right  { text-align: right  !important; }
</style>

<script>
    function handleSearch(event, formElement) {
        event.preventDefault();
        const searchParams = new URLSearchParams(new FormData(formElement)).toString();
        const url = `${formElement.action}?${searchParams}`;
        const container = document.getElementById('pageContent');
        if (container) {
            const btn = formElement.querySelector('.search-btn');
            btn.textContent = '...';
            btn.disabled = true;
            fetch(url)
                .then(r => r.text())
                .then(html => {
                    container.innerHTML = html;
                    container.classList.add('page-fade-in');
                })
                .catch(() => { window.location.href = url; });
        }
    }

    function clearSearch(event) {
        event.preventDefault();
        const container = document.getElementById('pageContent');
        if (container) {
            fetch('/Books/Products?partial=true')
                .then(r => r.text())
                .then(html => { container.innerHTML = html; });
        }
    }
</script>
