@page
@model RazorPageBooks.Pages.Books.DeleteModel

@{
    ViewData["Title"] = "Delete Book";
}
 <link rel="stylesheet" href="~/css/delete.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<div class="page-wrapper">

    <!-- Page Header -->
    <div class="page-header">
        <div class="text-center">
            <h1 class="page-title">Delete Entry.</h1>
            <p class="page-subtitle">This action cannot be undone.</p>
        </div>
        <a asp-page="Index" class="back-btn">
            <i class="bi bi-arrow-left"></i> Back to Library
        </a>
    </div>

    <!-- Card -->
    <div class="form-card">
        <div class="card-accent"></div>

        <div class="card-inner">

            <!-- Warning Banner -->
            <div class="warning-banner">
                <i class="bi bi-exclamation-triangle-fill"></i>
                Are you sure you want to remove <strong>@Model.Book.Title</strong> from the cellar?
            </div>

            <!-- Book Info Grid -->
            <div class="info-grid">
                <div class="form-row two-col">
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-book"></i> Book Title</label>
                        <div class="display-field">@Model.Book.Title</div>
                    </div>
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-person"></i> Author</label>
                        <div class="display-field">@Model.Book.Author</div>
                    </div>
                </div>

                <div class="form-row two-col">
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-calendar3"></i> Year Published</label>
                        <div class="display-field">@Model.Book.YearPublished</div>
                    </div>
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-building"></i> Publisher</label>
                        <div class="display-field">@Model.Book.Publisher</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Book.ImageUrl))
                {
                    <div class="form-row">
                        <div class="field-group cover-row">
                            <label class="field-label"><i class="bi bi-image"></i> Cover</label>
                            <div class="cover-preview-wrap">
                                <img src="@Model.Book.ImageUrl" alt="Cover"
                                     class="cover-thumb"
                                     onerror="this.src='https://via.placeholder.com/60x85?text=?'" />
                                <div class="display-field cover-url">@Model.Book.ImageUrl</div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Actions -->
            <form method="post">
                <input type="hidden" asp-for="Book.Id" />
                <div class="form-actions">
                    <button type="submit" class="btn-delete">
                        <i class="bi bi-trash3"></i> Yes, Delete
                    </button>
                    <a asp-page="./Index" class="btn-cancel">Cancel</a>
                </div>
            </form>

        </div>
    </div>
</div>
