@page
@model RazorPageBooks.Pages.Books.DeleteModel

@{
    ViewData["Title"] = "Delete Book";
}

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg p-4 create-card">
        <h2 class="text-center mb-2 text-danger">Delete</h2>
        <p class="text-center mb-4">
            Are you sure you want to delete this book?
        </p>

        <dl class="row mb-4">
            <dt class="col-sm-4 fw-bold">Title</dt>
            <dd class="col-sm-8">@Model.Book.Title</dd>

            <dt class="col-sm-4 fw-bold">Author</dt>
            <dd class="col-sm-8">@Model.Book.Author</dd>

            <dt class="col-sm-4 fw-bold">Year Published</dt>
            <dd class="col-sm-8">@Model.Book.YearPublished</dd>
        </dl>

        <form method="post">
            <input type="hidden" asp-for="Book.Id" />

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-danger btn-lg">
                    Delete
                </button>
            </div>

            <div class="text-center">
                <a asp-page="./Index" class="text-decoration-none">
                    ← Back to List
                </a>
            </div>
        </form>
    </div>
</div>
