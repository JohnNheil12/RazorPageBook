@page
@model RazorPageBooks.Pages.Books.DeleteModel
@{
    Layout = null;
    ViewData["Title"] = "Delete Book";
}
<link rel="stylesheet" href="/css/delete.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">


<div class="del-page">
    <div class="del-header">
        <div>
            <div class="del-eyebrow">System / Inventory</div>
            <h1 class="del-title">Delete <em>Entry</em></h1>
            <p class="del-sub">This action is permanent and cannot be undone.</p>
        </div>
    </div>

    <div class="warn-banner">
        <i class="bi bi-exclamation-triangle-fill"></i>
        You are about to permanently remove <strong>&nbsp;@Model.Book.Title&nbsp;</strong> from The Book Cellar.
    </div>

    <div class="del-card">
        <div class="del-card-ttl"><i class="bi bi-book"></i> Book Record</div>

        <div class="book-hero">
            @if (!string.IsNullOrEmpty(Model.Book.ImageUrl))
            {
                <img src="@Model.Book.ImageUrl" alt="Cover" class="hero-cover"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                <div class="hero-cover-ph" style="display:none"><i class="bi bi-book"></i></div>
            }
            else
            {
                <div class="hero-cover-ph"><i class="bi bi-book"></i></div>
            }
            <div>
                <div class="hero-badge"><i class="bi bi-trash3"></i> Marked for deletion</div>
                <div class="hero-title">@Model.Book.Title</div>
                <div class="hero-author">by @Model.Book.Author</div>
            </div>
        </div>

        <div class="fields-grid">
            <div>
                <div class="field-lbl"><i class="bi bi-calendar3"></i> Year Published</div>
                <div class="field-val">@Model.Book.YearPublished</div>
            </div>
            <div>
                <div class="field-lbl"><i class="bi bi-building"></i> Publisher</div>
                <div class="field-val">@(string.IsNullOrEmpty(Model.Book.Publisher) ? "—" : Model.Book.Publisher)</div>
            </div>
            <div>
                <div class="field-lbl"><i class="bi bi-tags"></i> Category</div>
                <div class="field-val">@(string.IsNullOrEmpty(Model.Book.Category) ? "—" : Model.Book.Category)</div>
            </div>
            <div>
                <div class="field-lbl"><i class="bi bi-cash"></i> Price</div>
                <div class="field-val">₱ @Model.Book.Price</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Book.Overview))
            {
                <div class="full-col">
                    <div class="field-lbl"><i class="bi bi-card-text"></i> Overview</div>
                    <div class="field-val overview">@Model.Book.Overview</div>
                </div>
            }
        </div>

        <!-- crud-form: Dashboard submit listener intercepts this -->
        <form method="post" action="/Books/Delete?id=@Model.Book.Id" class="crud-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Book.Id" />
            <div class="del-actions">
                <button type="submit" class="btn-delete">
                    <i class="bi bi-trash3-fill"></i> Yes, Delete Permanently
                </button>
                <button type="button" class="btn-keep"
                        onclick="(function(){var n=document.querySelector('.nav-item[data-page=products]');if(n)loadTab(n,'products');})()">
                    Keep this Record
                </button>
            </div>
        </form>
    </div>
</div>
