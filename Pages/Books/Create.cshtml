@page
@model RazorPageBooks.Pages.Books.CreateModel

@{
    ViewData["Title"] = "Add New Book";
}

<link rel="stylesheet" href="~/css/create.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="page-header">
        <div>
            <h1 class="page-title">New Entry.</h1>
            <p class="page-subtitle">Add a new book to the cellar.</p>
        </div>
        <a asp-page="Index" class="back-btn">
            <i class="bi bi-arrow-left"></i> Back to Library
        </a>
    </div>

    <!-- FORM CARD -->
    <div class="form-card">
        <div class="card-accent"></div>

        <div class="card-inner">
            <form method="post" class="book-form">

                <div asp-validation-summary="ModelOnly" class="validation-alert"></div>

                <!-- TITLE + AUTHOR -->
                <div class="form-row two-col">
                    <div class="field-group">
                        <label asp-for="Book.Title" class="field-label">
                            <i class="bi bi-book"></i> Book Title
                        </label>
                        <input asp-for="Book.Title" class="field-input" placeholder="The Great Gatsby" />
                        <span asp-validation-for="Book.Title" class="field-error"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Book.Author" class="field-label">
                            <i class="bi bi-person"></i> Author Name
                        </label>
                        <input asp-for="Book.Author" class="field-input" placeholder="F. Scott Fitzgerald" />
                        <span asp-validation-for="Book.Author" class="field-error"></span>
                    </div>
                </div>

                <!-- YEAR + PUBLISHER -->
                <div class="form-row two-col">
                    <div class="field-group">
                        <label asp-for="Book.YearPublished" class="field-label">
                            <i class="bi bi-calendar3"></i> Year Published
                        </label>
                        <input asp-for="Book.YearPublished" class="field-input" placeholder="YYYY" />
                        <span asp-validation-for="Book.YearPublished" class="field-error"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Book.Publisher" class="field-label">
                            <i class="bi bi-building"></i> Publisher
                        </label>
                        <input asp-for="Book.Publisher" class="field-input" placeholder="Publisher Name" />
                        <span asp-validation-for="Book.Publisher" class="field-error"></span>
                    </div>
                </div>

                <!-- PRICE + CATEGORY -->
                <div class="form-row two-col">
                    <div class="field-group">
                        <label asp-for="Book.Price" class="field-label">
                            <i class="bi bi-currency-dollar"></i> Price
                        </label>

                        <div class="price-input-wrap">
                            <span>₱</span>
                            <input asp-for="Book.Price" class="field-input" placeholder="0.00" />
                        </div>

                        <span asp-validation-for="Book.Price" class="field-error"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Book.Category" class="field-label">
                            <i class="bi bi-tags"></i> Category
                        </label>

                        <select asp-for="Book.Category" class="field-input">
                            <option value="">Select category</option>
                            <option>Fiction</option>
                            <option>Non-Fiction</option>
                            <option>Science</option>
                            <option>Romance</option>
                            <option>History</option>
                        </select>

                        <span asp-validation-for="Book.Category" class="field-error"></span>
                    </div>
                </div>

                <!-- OVERVIEW -->
                <div class="form-row">
                    <div class="field-group">
                        <label asp-for="Book.Overview" class="field-label">
                            <i class="bi bi-card-text"></i> Overview
                        </label>

                        <textarea asp-for="Book.Overview" class="field-input"
                                  placeholder="Write a short description..."></textarea>

                        <span asp-validation-for="Book.Overview" class="field-error"></span>
                    </div>
                </div>

                <!-- IMAGE -->
                <div class="form-row">
                    <div class="field-group">
                        <label asp-for="Book.ImageUrl" class="field-label">
                            <i class="bi bi-image"></i> Cover Image URL
                        </label>

                        <div class="url-field-wrap">
                            <input asp-for="Book.ImageUrl" class="field-input"
                                   id="imageUrlInput"
                                   placeholder="https://example.com/image.jpg" />

                            <div class="cover-preview">
                                <img id="previewImg" />
                                <span class="preview-placeholder">
                                    <i class="bi bi-image"></i>
                                </span>
                            </div>
                        </div>

                        <span asp-validation-for="Book.ImageUrl" class="field-error"></span>
                    </div>
                </div>

                <!-- BUTTONS -->
                <div class="form-actions">
                    <button type="submit" class="btn-create">
                        <i class="bi bi-plus-lg"></i> Create Record
                    </button>
                    <a asp-page="Index" class="btn-cancel">Cancel</a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const input = document.getElementById('imageUrlInput');
        const img = document.getElementById('previewImg');
        const placeholder = document.querySelector('.preview-placeholder');

        input.addEventListener('input', function () {
            const url = this.value.trim();
            if (url) {
                img.src = url;
                img.style.display = 'block';
                placeholder.style.display = 'none';
                img.onerror = () => {
                    img.style.display = 'none';
                    placeholder.style.display = 'flex';
                };
            } else {
                img.style.display = 'none';
                placeholder.style.display = 'flex';
            }
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}