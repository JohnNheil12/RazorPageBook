@page
@model RazorPageBooks.Pages.Books.CreateModel
@{
    Layout = null;
    ViewData["Title"] = "Add New Book";
}
<link rel="stylesheet" href="/css/create.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<div class="cr-page">
    <div class="cr-header">
        <div>
            <div class="cr-eyebrow">System / Inventory</div>
            <h1 class="cr-title">New <em>Entry</em></h1>
            <p class="cr-sub">Fill in the details to add a new volume to The Book Cellar.</p>
        </div>
    </div>

    <!-- crud-form: Dashboard.cshtml listens for this class and handles the POST via fetch -->
    <form method="post" action="/Books/Create" class="crud-form">
        @Html.AntiForgeryToken()

        <div class="cr-grid">
            <div>
                <div class="cr-card">
                    <div class="cr-card-ttl"><i class="bi bi-book"></i> Book Information</div>
                    <div asp-validation-summary="ModelOnly" class="val-alert"></div>

                    <div class="field-group">
                        <label asp-for="Book.Title" class="field-label"><i class="bi bi-bookmark-plus"></i> Book Title</label>
                        <input asp-for="Book.Title" class="field-input" placeholder="e.g. The Great Gatsby" autocomplete="off" />
                        <span asp-validation-for="Book.Title" class="field-error"></span>
                    </div>
                    <div class="row-2">
                        <div class="field-group">
                            <label asp-for="Book.Author" class="field-label"><i class="bi bi-person"></i> Author</label>
                            <input asp-for="Book.Author" class="field-input" placeholder="Full name" autocomplete="off" />
                            <span asp-validation-for="Book.Author" class="field-error"></span>
                        </div>
                        <div class="field-group">
                            <label asp-for="Book.Category" class="field-label"><i class="bi bi-tag"></i> Category</label>
                            <select asp-for="Book.Category" class="field-input">
                                <option value="">— Select —</option>
                                <option>Fiction</option><option>Non-Fiction</option>
                                <option>Science</option><option>Romance</option>
                                <option>History</option><option>Biography</option><option>Fantasy</option>
                            </select>
                        </div>
                    </div>
                    <div class="field-group">
                        <label asp-for="Book.Overview" class="field-label"><i class="bi bi-chat-left-text"></i> Overview</label>
                        <textarea asp-for="Book.Overview" class="field-input" placeholder="Brief description…"></textarea>
                    </div>
                </div>

                <div class="cr-card">
                    <div class="cr-card-ttl"><i class="bi bi-building"></i> Publishing & Pricing</div>
                    <div class="row-3">
                        <div class="field-group">
                            <label asp-for="Book.YearPublished" class="field-label"><i class="bi bi-calendar3"></i> Year</label>
                            <input asp-for="Book.YearPublished" class="field-input" type="number" placeholder="YYYY" autocomplete="off" />
                            <span asp-validation-for="Book.YearPublished" class="field-error"></span>
                        </div>
                        <div class="field-group">
                            <label asp-for="Book.Publisher" class="field-label"><i class="bi bi-building"></i> Publisher</label>
                            <input asp-for="Book.Publisher" class="field-input" placeholder="Publisher name" autocomplete="off" />
                        </div>
                        <div class="field-group">
                            <label asp-for="Book.Price" class="field-label">₱ Price</label>
                            <input asp-for="Book.Price" class="field-input" type="number" step="0.01" placeholder="0.00" autocomplete="off" />
                        </div>
                    </div>
                </div>
            </div>

            <div>
                <div class="cr-card">
                    <div class="cr-card-ttl"><i class="bi bi-image"></i> Cover Preview</div>
                    <div class="preview-box">
                        <img id="previewImg" src="" alt="Preview" />
                        <div class="preview-ph" id="previewPh"><i class="bi bi-cloud-arrow-up"></i><span>Paste URL below</span></div>
                    </div>
                    <div class="field-group" style="margin-bottom:0">
                        <label asp-for="Book.ImageUrl" class="field-label"><i class="bi bi-link-45deg"></i> Image URL</label>
                        <input asp-for="Book.ImageUrl" class="field-input" id="imageUrlInput" placeholder="https://…" autocomplete="off" />
                    </div>
                </div>
                <div class="cr-card">
                    <div class="cr-actions">
                        <button type="submit" class="btn-save"><i class="bi bi-plus-lg"></i> Save Record</button>
                        <button type="button" class="btn-cancel"
                                onclick="(function(){var n=document.querySelector('.nav-item[data-page=products]');if(n)loadTab(n,'products');})()">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
(function(){
    var inp=document.getElementById('imageUrlInput'),
        img=document.getElementById('previewImg'),
        ph=document.getElementById('previewPh');
    if(!inp)return;
    inp.addEventListener('input',function(){
        var url=this.value.trim();
        if(url){img.src=url;img.onload=function(){img.style.display='block';ph.style.display='none';};img.onerror=function(){img.style.display='none';ph.style.display='flex';};}
        else{img.style.display='none';ph.style.display='flex';}
    });
})();
</script>
