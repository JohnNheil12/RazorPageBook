@page
@model RazorPageBooks.Pages.Books.CreateModel

@{
    ViewData["Title"] = "Create Book";
}

<div class="d-flex justify-content-center align-items-center min-vh-100 ">
    <div class="card shadow-lg p-4 create-card">
        <h2 class="text-center mb-1">Create</h2>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Book.Title" class="form-label"></label>
                <input asp-for="Book.Title" class="form-control" />
                <span asp-validation-for="Book.Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Book.Author" class="form-label">Author</label>
                <input asp-for="Book.Author" class="form-control" />
                <span asp-validation-for="Book.Author" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Book.YearPublished" class="form-label">Year Published</label>
                <input asp-for="Book.YearPublished" class="form-control" />
                <span asp-validation-for="Book.YearPublished" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Book.Publisher" class="form-label">Publisher</label>
                <input asp-for="Book.Publisher" class="form-control" />
                <span asp-validation-for="Book.Publisher" class="text-danger"></span>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary btn-lg">
                    Create
                </button>
            </div>

            <div class="text-center">
                <a asp-page="Index" class="text-decoration-none">
                    ← Back to List
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
