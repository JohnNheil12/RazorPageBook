@page
@model RazorPageBooks.Pages.Books.DetailsModel

@{
    ViewData["Title"] = "Book Details";
}
 <link rel="stylesheet" href="~/css/details.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<div class="page-wrapper">

    <!-- Page Header -->
    <div class="page-header">
        <div class="text-center">
            <h1 class="page-title">Book Details.</h1>
            <p class="page-subtitle">Full information for the selected record.</p>
        </div>
        <a asp-page="Index" class="back-btn">
            <i class="bi bi-arrow-left"></i> Back to Library
        </a>
    </div>

    <!-- Card -->
    <div class="form-card">
        <div class="card-accent"></div>

        <div class="card-inner">

            <!-- Cover + Title Hero -->
            <div class="book-hero">
                <img src="@(string.IsNullOrEmpty(Model.Book.ImageUrl) ? "https://via.placeholder.com/90x130?text=?" : Model.Book.ImageUrl)"
                     alt="Cover"
                     class="hero-cover"
                     onerror="this.src='https://via.placeholder.com/90x130?text=?'" />
                <div class="hero-meta">
                    <div class="hero-title">@Model.Book.Title</div>
                    <div class="hero-author">by @Model.Book.Author</div>
                    <span class="hero-badge">
                        <i class="bi bi-calendar3"></i> @Model.Book.YearPublished
                    </span>
                </div>
            </div>

            <!-- Info Grid -->
            <div class="info-grid">
                <div class="form-row two-col">
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-book"></i> Book Title</label>
                        <div class="display-field">@Html.DisplayFor(model => model.Book.Title)</div>
                    </div>
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-person"></i> Author</label>
                        <div class="display-field">@Html.DisplayFor(model => model.Book.Author)</div>
                    </div>
                </div>

                <div class="form-row two-col">
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-calendar3"></i> Year Published</label>
                        <div class="display-field">@Html.DisplayFor(model => model.Book.YearPublished)</div>
                    </div>
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-building"></i> Publisher</label>
                        <div class="display-field">@Html.DisplayFor(model => model.Book.Publisher)</div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <a asp-page="./Edit" asp-route-id="@Model.Book.Id" class="btn-edit">
                    <i class="bi bi-pencil"></i> Edit Details
                </a>
                <a asp-page="./Index" class="btn-cancel">← Return to Library</a>
            </div>

        </div>
    </div>
</div>
