@page
@model RazorPageBooks.Pages.Books.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg p-4 create-card">

        <div>
            <h4 class="text-center">Book Information</h4>
            <hr />
            <dl class="row mb-4">
                <dt class="col-sm-4 fw-bold">Title</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Book.Title)</dd>

                <dt class="col-sm-4 fw-bold">Author</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Book.Author)</dd>

                <dt class="col-sm-4 fw-bold">Year Published</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Book.YearPublished)</dd>
            </dl>
        </div>

        <!-- Edit and Back to List buttons -->
        <div class="text-center">
            <a asp-page="./Edit" asp-route-id="@Model.Book.Id" class="btn btn-primary btn-lg mb-3">
                Edit
            </a>
            <br />
            <a asp-page="./Index" class="text-decoration-none">
                ← Back to List
            </a>
        </div>
    </div>
</div>
