@page
@model RazorPageBooks.Pages.AboutModel
@{
    ViewData["Title"] = "About — The Book Cellar";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

<!-- ═══════════════════════════════════════════════
     HERO BANNER  (matches Index banner aesthetic)
════════════════════════════════════════════════════ -->
<div class="about-hero">
    <!-- Ambient glow blooms -->
    <div class="hero-bloom hb1"></div>
    <div class="hero-bloom hb2"></div>

    <!-- Floating dust -->
