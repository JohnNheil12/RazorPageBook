            <rect x="259" y="135" width="7" height="5" rx="1" fill="#2a1f0e"/>
            <rect x="255" y="139" width="15" height="3" rx="1" fill="#2a1f0e"/>
            <rect x="280" y="66"  width="22" height="76" rx="2" fill="#1f3d1f"/>
            <rect x="305" y="78"  width="18" height="64" rx="2" fill="#c8b89a"/>
            <rect x="326" y="60"  width="24" height="82" rx="2" fill="#3a1a5c"/>
            <rect x="354" y="68"  width="20" height="74" rx="2" fill="#5c3010"/>
            <rect x="378" y="74"  width="22" height="68" rx="2" fill="#1a2a7a"/>
            <rect x="404" y="62"  width="26" height="80" rx="2" fill="#384050"/>
            <rect x="434" y="70"  width="20" height="72" rx="2" fill="#7a1c1c"/>
            <rect x="460" y="58"  width="28" height="84" rx="2" fill="#1c3a2a"/>
            <rect x="464" y="70"  width="18" height="2"  rx="1" fill="rgba(201,168,76,0.5)"/>
            <rect x="492" y="75"  width="22" height="67" rx="2" fill="#4a3b1c"/>
            <rect x="518" y="64"  width="24" height="78" rx="2" fill="#1a2a4a"/>
            <!-- small open book -->
            <g transform="translate(548,110)">
                <path d="M0,28 Q15,22 30,28 L30,8 Q15,14 0,8 Z" fill="#e8d5b0" opacity="0.9"/>
                <line x1="15" y1="8" x2="15" y2="28" stroke="rgba(80,60,30,0.4)" stroke-width="1"/>
            </g>
            <rect x="584" y="68"  width="22" height="74" rx="2" fill="#5a3010"/>
            <rect x="610" y="60"  width="26" height="82" rx="2" fill="#2d1f4a"/>
            <rect x="640" y="72"  width="20" height="70" rx="2" fill="#1a4040"/>
