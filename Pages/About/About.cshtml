        <span class="dust d1"></span><span class="dust d2"></span>
        <span class="dust d3"></span><span class="dust d4"></span>
        <span class="dust d5"></span><span class="dust d6"></span>
    </div>

    <!-- Bookshelf SVG (same as Login/ChangePassword brand panel) -->
    <div class="hero-shelf" aria-hidden="true">
        <svg viewBox="0 0 900 180" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
            <rect x="0" y="140" width="900" height="8" rx="2" fill="#2a1f0e"/>
            <rect x="0" y="140" width="900" height="3" rx="1" fill="rgba(201,168,76,0.22)"/>
