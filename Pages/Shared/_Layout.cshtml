<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The Book Cellar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RazorPageBooks.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<header>
    <nav class="site-navbar">
        <div class="nav-inner">

            <a class="nav-brand" asp-area="" asp-page="/Index">
                <span class="brand-icon"><i class="bi bi-book-half"></i></span>
                <span class="brand-text">The Book Cellar</span>
            </a>
                <div class="nav-right">
            
            </ul>

            <div class="nav-auth">
                <partial name="_LoginPartial" />
            </div>

            <button class="mobile-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNav">
                <i class="bi bi-list"></i>
            </button>
        </div>
            </div>
        <div class="collapse mobile-nav" id="mobileNav">
            <div class="mobile-nav-inner">
                <form method="get" asp-page="/Books/Index" class="mobile-search-form">
                    <div class="mobile-search-box">
                        <i class="bi bi-search" style="color:#aaa;"></i>
                        <input type="text" name="SearchString" class="mobile-search-input" placeholder="Search books..." />
                        <button type="submit" class="mobile-search-btn">
                            <i class="bi bi-arrow-right"></i>
                        </button>
                    </div>
                </form>
                <a class="mobile-nav-link" asp-area="" asp-page="/Books/Index"><i class="bi bi-house"></i> Home</a>
                <div class="mobile-nav-auth">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>
</header>

<div class="page-body">
    <main role="main" class="pb-5">
        @RenderBody()
    </main>
</div>

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-left">
            <span class="footer-brand"><i class="bi bi-book-half"></i> The Book Cellar</span>
            <span class="footer-tagline">Curating your literary collection.</span>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

<script>
    // ✅ Modification 2: Wrap script in conditional check
    const searchInput = document.getElementById('navSearchInput');
    const dropdown = document.getElementById('searchDropdown');
    
    if (searchInput) {
        let debounceTimer;

        searchInput.addEventListener('input', function () {
            clearTimeout(debounceTimer);
            const query = this.value.trim();

            if (query.length < 2) {
                dropdown.style.display = 'none';
                dropdown.innerHTML = '';
                return;
            }

            debounceTimer = setTimeout(() => {
                fetch(`/Books/Index?handler=Search&searchString=${encodeURIComponent(query)}`)
                    .then(r => r.json())
                    .then(data => {
                        if (!data || data.length === 0) {
                            dropdown.innerHTML = `<div class="sd-empty"><i class="bi bi-search"></i> No results for "<strong>${query}</strong>"</div>`;
                        } else {
                            dropdown.innerHTML = data.slice(0, 6).map(book => `
                                <a href="/Books/Details?id=${book.id}" class="sd-item">
                                    <div class="sd-cover">
                                        <img src="${book.imageUrl || 'https://via.placeholder.com/36x50?text=?'}" onerror="this.src='https://via.placeholder.com/36x50?text=?'" />
                                    </div>
                                    <div class="sd-info">
                                        <div class="sd-title">${book.title}</div>
                                        <div class="sd-author">by ${book.author} · ${book.yearPublished}</div>
                                    </div>
                                    <i class="bi bi-arrow-right sd-arrow"></i>
                                </a>`).join('');

                            if (data.length > 6) {
                                dropdown.innerHTML += `<a href="/Books/Index?SearchString=${encodeURIComponent(query)}" class="sd-viewall">View all ${data.length} results <i class="bi bi-arrow-right"></i></a>`;
                            }
                        }
                        dropdown.style.display = 'block';
                    })
                    .catch(() => { dropdown.style.display = 'none'; });
            }, 300);
        });

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.nav-search-form')) {
                dropdown.style.display = 'none';
            }
        });

        searchInput.addEventListener('focus', function () {
            if (this.value.trim().length >= 2 && dropdown.innerHTML !== '') {
                dropdown.style.display = 'block';
            }
        });
    }
</script>
</body>
</html>

<style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #f4f5f7;
        margin: 0;
        color: #1a1a1a;
    }
    /* ══════════════════════════
       NAVBAR
    ══════════════════════════ */
    .site-navbar {
        background: #fff;
        border-bottom: 1px solid rgba(0,0,0,0.07);  
        box-shadow: 0 1px 12px rgba(0,0,0,0.05);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .nav-inner {
        width: 100%;
        padding: 0 40px;
        height: 64px;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    /* ── Brand ── */
    .nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        flex-shrink: 0;
    }

    .brand-icon {
        width: 36px;
        height: 36px;
        background: #111;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .brand-text {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: #111;
        letter-spacing: -0.3px;
        white-space: nowrap;
    }

    .nav-brand:hover .brand-text { color: #444; }

    /* ── Search Bar ── */
    .nav-search-form {
        flex: 1;
        max-width: 460px;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .nav-search-box {
        display: flex;
        align-items: center;
        background: #f4f5f7;
        border: 1.5px solid #e8e8e8;
        border-radius: 12px;
        padding: 0 6px 0 14px;
        height: 42px;
        gap: 8px;
        transition: all 0.2s;
    }

    .nav-search-form:focus-within .nav-search-box {
        background: #fff;
        border-color: #111;
        box-shadow: 0 0 0 4px rgba(17,17,17,0.06);
    }

    .search-icon { color: #aaa; font-size: 0.9rem; flex-shrink: 0; }

    .nav-search-input {
        flex: 1;
        border: none;
        background: transparent;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem;
        color: #111;
        outline: none;
        min-width: 0;
    }

    .nav-search-input::placeholder { color: #bbb; }

    .nav-search-btn {
        background: #111;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 0 14px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        height: 30px;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.15s;
        flex-shrink: 0;
    }

    .nav-search-btn:hover { background: #333; }

    /* ── Dropdown ── */
    .search-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 14px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
        overflow: hidden;
        z-index: 9999;
    }

    .sd-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        text-decoration: none;
        color: #222;
        border-bottom: 1px solid #f5f5f5;
        transition: background 0.15s;
    }

    .sd-item:hover { background: #f4f5f7; }
    .sd-item:last-of-type { border-bottom: none; }

    .sd-cover {
        width: 36px;
        height: 50px;
        border-radius: 6px;
        overflow: hidden;
        flex-shrink: 0;
        background: #f0f0f0;
    }

    .sd-cover img { width: 100%; height: 100%; object-fit: cover; }
    .sd-info { flex: 1; min-width: 0; }

    .sd-title {
        font-size: 0.875rem;
        font-weight: 600;
        color: #111;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sd-author { font-size: 0.78rem; color: #999; margin-top: 2px; }
    .sd-arrow  { color: #ccc; font-size: 0.85rem; flex-shrink: 0; }

    .sd-empty {
        padding: 20px 16px;
        text-align: center;
        font-size: 0.875rem;
        color: #aaa;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .sd-viewall {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 12px;
        font-size: 0.82rem;
        font-weight: 600;
        color: #111;
        text-decoration: none;
        background: #f9f9f9;
        border-top: 1px solid #f0f0f0;
        transition: background 0.15s;
    }

    .sd-viewall:hover { background: #f0f2f5; }

    /* ── Nav Links ── */
    .nav-links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 2px;
        margin-left: auto; /* ✅ THIS pushes it to the right */
    }
    .nav-link-item {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        color: #666;
        text-decoration: none;
        transition: all 0.15s ease;
        white-space: nowrap;
    }

    .nav-link-item:hover { background: #f4f5f7; color: #111; }

    .nav-link-register {
        background: #111;
        color: #fff !important;
        border-radius: 20px;
        padding: 7px 16px;
        margin-left: 4px;
        font-size: 0.85rem;
    }

    .nav-link-register:hover {
        background: #2d2d2d !important;
        color: #fff !important;
    }

    /* ── Auth ── */
    .nav-auth {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .nav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .nav-auth a,
    .nav-auth button {
        font-size: 0.875rem !important;
        font-weight: 500 !important;
        font-family: 'DM Sans', sans-serif !important;
    }

    /* ── Mobile Toggle ── */
    .mobile-toggle {
        display: none;
        background: none;
        border: 1px solid #e8e8e8;
        border-radius: 8px;
        width: 38px;
        height: 38px;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #333;
        cursor: pointer;
        margin-left: auto;
        transition: all 0.15s;
    }

    .mobile-toggle:hover { background: #f4f5f7; border-color: #ccc; }

    /* ── Mobile Nav ── */
    .mobile-nav { border-top: 1px solid #f0f0f0; background: #fff; }

    .mobile-nav-inner {
        padding: 12px 40px 16px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .mobile-search-form { width: 100%; }

    .mobile-search-box {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f4f5f7;
        border: 1.5px solid #e8e8e8;
        border-radius: 10px;
        padding: 0 8px 0 14px;
        height: 44px;
        margin-bottom: 6px;
    }

    .mobile-search-input {
        flex: 1;
        border: none;
        background: transparent;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        color: #111;
        outline: none;
    }

    .mobile-search-input::placeholder { color: #bbb; }

    .mobile-search-btn {
        background: #111;
        color: #fff;
        border: none;
        border-radius: 8px;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .mobile-nav-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 500;
        color: #444;
        text-decoration: none;
        transition: background 0.15s;
    }

    .mobile-nav-link:hover { background: #f4f5f7; color: #111; }

    .mobile-nav-register {
        background: #111;
        color: #fff !important;
        border-radius: 20px;
        width: fit-content;
        padding: 9px 18px;
        margin-top: 4px;
    }

    .mobile-nav-register:hover {
        background: #2d2d2d !important;
        color: #fff !important;
    }

    .mobile-nav-auth {
        padding-top: 12px;
        margin-top: 8px;
        border-top: 1px solid #f0f0f0;
    }

    /* ══════════════════════════
       PAGE BODY
    ══════════════════════════ */
    .page-body {
        min-height: calc(100vh - 64px - 72px);
    }

    /* ══════════════════════════
       FOOTER
    ══════════════════════════ */
    .site-footer {
        background: #fff;
        border-top: 1px solid rgba(0,0,0,0.07);
        padding: 20px 0;
    }

    .footer-inner {
        width: 100%;
        padding: 0 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
    }

    .footer-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .footer-brand {
        font-family: 'Playfair Display', serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: #111;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .footer-tagline {
        font-size: 0.8rem;
        color: #bbb;
        padding-left: 12px;
        border-left: 1px solid #e8e8e8;
    }

    .footer-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .footer-copy { font-size: 0.82rem; color: #aaa; }
    .footer-dot  { color: #ccc; font-size: 0.8rem; }

    .footer-link {
        font-size: 0.82rem;
        color: #aaa;
        text-decoration: none;
        transition: color 0.15s;
    }

    .footer-link:hover { color: #111; }

    /* ══════════════════════════
       RESPONSIVE
    ══════════════════════════ */
    @@media (max-width: 768px) {
        .nav-search-form { display: none; }
        .nav-links       { display: none; }
        .nav-auth        { display: none; }
        .mobile-toggle   { display: inline-flex; }
        .footer-left     { flex-direction: column; align-items: center; gap: 4px; }
        .footer-tagline  { border-left: none; padding-left: 0; }
        .footer-inner    { justify-content: center; text-align: center; }
    }
</style>