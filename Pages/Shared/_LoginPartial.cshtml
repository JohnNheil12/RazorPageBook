@using Microsoft.AspNetCore.Identity

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav ms-auto d-flex align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item me-3 d-flex align-items-center">
            <a class="nav-link text-dark pe-2" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                Hello, @UserManager.GetUserName(User)!
            </a>
            <form id="logoutForm" class="d-inline m-0 p-0" method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                <button type="submit" class="btn btn-link text-dark p-0 m-0">Logout</button>
            </form>
        </li>
    }
    else
    {
        @* <li class="nav-item me-2">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li> *@
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>
