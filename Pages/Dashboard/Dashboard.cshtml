@page
@model DashboardModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    Layout = null;
    ViewData["Title"] = "Book Cellar — Admin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>
<div class="shell">

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-book-half"></i></div>
            <div class="brand-text">
                <span class="brand-name">Book Cellar</span>
                <span class="brand-tagline">Admin Panel</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Library</span>

            <a href="#" class="nav-item" data-page="products" onclick="loadTab(this,'products')">
                <div class="nav-icon-wrap"><i class="bi bi-journals"></i></div>
                <span class="nav-label">Products</span>
            </a>
            <a href="#" class="nav-item" data-page="orders" onclick="loadTab(this,'orders')">
                <div class="nav-icon-wrap"><i class="bi bi-bag-check"></i></div>
                <span class="nav-label">Orders</span>
            </a>
            <a href="#" class="nav-item" data-page="profit" onclick="loadTab(this,'profit')">
                <div class="nav-icon-wrap"><i class="bi bi-graph-up-arrow"></i></div>
                <span class="nav-label">Profit</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a href="#" class="nav-item" data-page="users" onclick="loadTab(this,'users')">
                    <div class="nav-icon-wrap"><i class="bi bi-people"></i></div>
                    <span class="nav-label">Users</span>
                </a>
            }
            @if (!SignInManager.IsSignedIn(User))
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="nav-item">
                    <div class="nav-icon-wrap"><i class="bi bi-box-arrow-in-right"></i></div>
                    <span class="nav-label">Login</span>
                </a>
            }
        </nav>

        @if (SignInManager.IsSignedIn(User))
        {
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="user-avatar">
                        @(User.Identity.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U")
                    </div>
                    <div class="user-meta">
                        <span class="user-name">@User.Identity.Name</span>
                        <span class="user-role">
                            @if (User.IsInRole("Admin"))
                            {
                                @:Administrator
                            }
                            else if (User.IsInRole("Staff"))
                            {
                                @:Staff
                            }
                            else
                            {
                                @:User
                            }
                        </span>
                    </div>
                    <form method="post" asp-area="Identity" asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Page("/Index", new { area = "" })"
                          style="margin:0;padding:0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="user-logout" title="Sign out">
                            <i class="bi bi-box-arrow-left"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    </aside>

    <main class="main-content" id="mainContent">
        <div id="pageContent">
            <div class="loading-state">
                <div class="spinner"></div>
                <span>Loading...</span>
            </div>
        </div>
    </main>
</div>

<!-- ══ DELETE MODAL ══ -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-box">
        <div class="modal-icon"><i class="bi bi-trash3"></i></div>
        <div class="modal-title">Delete Account?</div>
        <div class="modal-body">
            You're about to permanently delete <strong id="modalUserName"></strong>'s account.
            This action cannot be undone and will remove all associated data.
        </div>
        <div class="modal-actions">
            <p id="modalAdminWarning"
               style="display:none; width:100%; font-size:0.8rem; color:#e11d48;
                      margin:0 0 12px; text-align:center; font-weight:600;">
                <i class="bi bi-shield-lock"></i> Admin accounts cannot be deleted.
            </p>
            <button class="btn-cancel" onclick="closeDeleteModal()">Cancel</button>
            <!-- Plain button — no form, no CSRF complexity. JS handles the fetch. -->
            <button class="btn-confirm-delete" id="btnConfirmDelete" onclick="doDeleteUser()">
                <i class="bi bi-trash3"></i> Yes, Delete
            </button>
        </div>
    </div>
</div>

<!-- ══ TOAST (lives in Dashboard so it's always available) ══ -->
<div class="toast-bar" id="toastBar"></div>

<style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; font-family: 'DM Sans', sans-serif; overflow: hidden; }

    :root {
        --sidebar-w: 260px;
        --sidebar-bg: #0b1120;
        --sidebar-border: rgba(255,255,255,0.06);
        --sidebar-txt: #6b7fa3;
        --sidebar-txt-active: #f1f5f9;
        --sidebar-hover: rgba(255,255,255,0.04);
        --sidebar-active-bg: rgba(59,130,246,0.12);
        --sidebar-accent: #3b82f6;
        --rose: #e11d48;
        --rose-bg: #fff1f2;
        --rose-border: #fecdd3;
        --surface: #ffffff;
        --border: #e2e8f0;
        --txt: #0f172a;
        --txt-muted: #64748b;
    }

    .shell { display: flex; height: 100vh; overflow: hidden; }

    /* SIDEBAR */
    .sidebar {
        width: var(--sidebar-w); min-width: var(--sidebar-w); max-width: var(--sidebar-w);
        background: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border);
        display: flex; flex-direction: column; height: 100vh; z-index: 200;
        box-shadow: 2px 0 20px rgba(0,0,0,0.25);
    }
    .sidebar-brand { display: flex; align-items: center; gap: 12px; padding: 24px 20px 22px; border-bottom: 1px solid var(--sidebar-border); }
    .brand-icon { width: 38px; height: 38px; border-radius: 11px; background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%); display: flex; align-items: center; justify-content: center; font-size: 1.05rem; color: #fff; box-shadow: 0 4px 14px rgba(79,70,229,0.45); }
    .brand-text { display: flex; flex-direction: column; }
    .brand-name { font-size: 0.9rem; font-weight: 700; color: #f1f5f9; letter-spacing: -0.2px; }
    .brand-tagline { font-size: 0.6rem; color: var(--sidebar-txt); text-transform: uppercase; letter-spacing: 1.2px; }

    .sidebar-nav { flex: 1; padding: 18px 12px; display: flex; flex-direction: column; gap: 1px; overflow-y: auto; }
    .nav-section-label { font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.4px; color: #2d3f5e; padding: 14px 10px 5px; }
    .nav-divider { height: 1px; background: var(--sidebar-border); margin: 10px 0; }
    .nav-item { display: flex; align-items: center; gap: 11px; padding: 10px 11px; border-radius: 10px; text-decoration: none; color: var(--sidebar-txt); font-size: 0.84rem; transition: 0.18s; cursor: pointer; border: 1px solid transparent; }
    .nav-item:hover { background: var(--sidebar-hover); color: #c8d6ef; }
    .nav-item.active { background: var(--sidebar-active-bg); color: #93c5fd; font-weight: 600; border-color: rgba(59,130,246,0.18); box-shadow: inset 3px 0 0 var(--sidebar-accent); }
    .nav-icon-wrap { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; background: rgba(255,255,255,0.03); flex-shrink: 0; }

    .sidebar-footer { padding: 14px 12px; border-top: 1px solid var(--sidebar-border); }
    .sidebar-user { display: flex; align-items: center; gap: 10px; padding: 10px 11px; border-radius: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.05); }
    .user-avatar { width: 32px; height: 32px; border-radius: 9px; background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff; font-size: 0.82rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .user-meta { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .user-name { font-size: 0.8rem; font-weight: 600; color: #e2e8f0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-role { font-size: 0.62rem; color: var(--sidebar-txt); }
    .user-logout { color: #4b5e7a; background: none; border: none; cursor: pointer; padding: 0; width: 28px; height: 28px; border-radius: 7px; transition: 0.18s; display: flex; align-items: center; justify-content: center; }
    .user-logout:hover { color: #f87171; background: rgba(248,113,113,0.1); }

    /* MAIN */
    .main-content { flex: 1; height: 100vh; overflow-y: auto; background: #f8fafc; }
    #pageContent { min-height: 100%; }

    /* Loading */
    .loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 60vh; gap: 14px; color: #94a3b8; }
    .spinner { width: 36px; height: 36px; border-radius: 50%; border: 3px solid #e2e8f0; border-top-color: #3b82f6; animation: spin 0.7s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .page-fade-in { animation: fadeUp 0.25s ease forwards; }
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

    /* Toast notifications (Dashboard-level) */
    .toast-notify {
        position: fixed; bottom: 28px; right: 28px;
        padding: 13px 20px; border-radius: 12px;
        font-size: 0.84rem; font-weight: 500; color: #fff;
        display: flex; align-items: center; gap: 9px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.18);
        z-index: 99999;
        animation: toastIn 0.3s ease;
        max-width: 320px;
    }
    .toast-notify.success { background: #059669; }
    .toast-notify.error   { background: #dc2626; }

    /* Toast bar (Users page style, kept for compatibility) */
    .toast-bar { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--txt); color: #fff; padding: 12px 20px; border-radius: 12px; font-size: 0.85rem; font-weight: 500; z-index: 99999; box-shadow: 0 8px 24px rgba(15,23,42,0.2); transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1); white-space: nowrap; pointer-events: none; }
    .toast-bar.show { transform: translateX(-50%) translateY(0); }
    .toast-bar.error { background: var(--rose); }

    @@keyframes toastIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes toastOut { from { opacity: 1; } to { opacity: 0; transform: translateY(12px); } }

    /* DELETE MODAL styles (live here so they're never stripped) */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,0.55); backdrop-filter: blur(4px); z-index: 9999; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal-box { background: var(--surface); border-radius: 18px; padding: 32px 28px; max-width: 420px; width: 90%; box-shadow: 0 20px 60px rgba(15,23,42,0.2); text-align: center; }
    .modal-icon { width: 56px; height: 56px; border-radius: 16px; background: var(--rose-bg); border: 1px solid var(--rose-border); color: var(--rose); font-size: 1.4rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
    .modal-title { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 700; color: var(--txt); margin-bottom: 8px; }
    .modal-body { font-size: 0.875rem; color: var(--txt-muted); margin-bottom: 24px; line-height: 1.5; }
    .modal-body strong { color: var(--txt); }
    .modal-actions { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
    .btn-cancel { padding: 10px 22px; border-radius: 10px; border: 1.5px solid var(--border); background: var(--surface); color: var(--txt); font-size: 0.875rem; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: background 0.15s; }
    .btn-cancel:hover { background: #f1f5f9; }
    .btn-confirm-delete { padding: 10px 22px; border-radius: 10px; border: none; background: var(--rose); color: #fff; font-size: 0.875rem; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: background 0.15s, opacity 0.15s; }
    .btn-confirm-delete:hover:not(:disabled) { background: #be123c; }
    /* ✅ Disabled state for confirm button when target is Admin */
    .btn-confirm-delete:disabled { opacity: 0.4; cursor: not-allowed; }

    @@media (max-width: 768px) {
        .shell { flex-direction: column; }
        .sidebar { width: 100% !important; max-width: none; height: auto; flex-direction: row; }
        .sidebar-brand { border-bottom: none; border-right: 1px solid var(--sidebar-border); }
        .sidebar-nav { flex-direction: row; overflow-x: auto; padding: 8px; }
        .nav-section-label, .sidebar-footer, .nav-divider { display: none; }
        .nav-item { padding: 8px 10px; }
        .main-content { height: calc(100vh - 64px); }
    }
</style>

<script>
    /* ── Page URL map ── */
    const pageUrls = {
        products: '/Books/Products',
        orders:   '/Orders/Orders',
        profit:   '/Profit/Profit',
        users:    '/Users/Users'
    };

    /* ── Toast (append-style, used by CRUD operations) ── */
    function showToast(msg, type = 'success') {
        const t = document.createElement('div');
        t.className = 'toast-notify ' + type;
        t.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> ${msg}`;
        document.body.appendChild(t);
        setTimeout(() => {
            t.style.animation = 'toastOut 0.3s ease forwards';
            setTimeout(() => t.remove(), 300);
        }, 3000);
    }

    /* ── Delete modal state ── */
    let _deleteUserId = '';

    function openDeleteModal(userId, userName, isAdmin) {
        _deleteUserId = userId;
        document.getElementById('modalUserName').textContent = userName;

        const btn     = document.getElementById('btnConfirmDelete');
        const warning = document.getElementById('modalAdminWarning');

        // Always reset button state first
        btn.disabled  = false;
        btn.innerHTML = '<i class="bi bi-trash3"></i> Yes, Delete';

        if (isAdmin) {
            btn.disabled = true;
            warning.style.display = 'block';
        } else {
            warning.style.display = 'none';
        }

        document.getElementById('deleteModal').classList.add('open');
    }

    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.remove('open');
    }

    document.getElementById('deleteModal').addEventListener('click', function(e) {
        if (e.target === this) closeDeleteModal();
    });

    /* ── doDeleteUser: called by the confirm button directly (no form involved) ── */
    async function doDeleteUser() {
        if (!_deleteUserId) return;

        const btn = document.getElementById('btnConfirmDelete');
        btn.disabled  = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Deleting…';

        try {
            // Fetch a fresh antiforgery token from the server each time,
            // so stale tokens never cause a 400 rejection.
            const tokenRes = await fetch('/Users/Users?handler=AntiforgeryToken', {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            const tokenJson = await tokenRes.json();

            const fd = new FormData();
            fd.append('__RequestVerificationToken', tokenJson.token);
            fd.append('userId', _deleteUserId);

            const res  = await fetch('/Users/Users?handler=DeleteUser', {
                method: 'POST',
                body: fd
            });

            // Try to parse as JSON; fall back gracefully if server returns HTML
            let json = { success: false, error: 'Unexpected server response.' };
            const ct = res.headers.get('content-type') || '';
            if (ct.includes('application/json')) {
                json = await res.json();
            } else if (res.ok) {
                json = { success: true };
            }

            closeDeleteModal();

            if (json.success) {
                showToast('✓ User deleted successfully.', 'success');
                const usersNav = document.querySelector('.nav-item[data-page="users"]');
                if (usersNav) loadTab(usersNav, 'users');
            } else {
                showToast(json.error || 'Delete failed. Please try again.', 'error');
                btn.disabled  = false;
                btn.innerHTML = '<i class="bi bi-trash3"></i> Yes, Delete';
            }
        } catch (err) {
            console.error('Delete error:', err);
            closeDeleteModal();
            showToast('Network error — please try again.', 'error');
            btn.disabled  = false;
            btn.innerHTML = '<i class="bi bi-trash3"></i> Yes, Delete';
        }
    }

    /* ── Users search/filter (must live here — never gets stripped by injectHTML) ── */
    function filterTable() {
        const searchEl = document.getElementById('searchInput');
        const roleEl   = document.getElementById('roleFilter');
        if (!searchEl) return;
        const q    = searchEl.value.toLowerCase();
        const role = roleEl ? roleEl.value.toLowerCase() : '';
        const rows = document.querySelectorAll('#usersTable tbody tr');
        let visible = 0;
        rows.forEach(row => {
            const name  = row.dataset.name  || '';
            const email = row.dataset.email || '';
            const r     = row.dataset.role  || '';
            const ok = (!q || name.includes(q) || email.includes(q)) && (!role || r === role);
            row.style.display = ok ? '' : 'none';
            if (ok) visible++;
        });
        const countEl = document.getElementById('rowCount');
        if (countEl) countEl.textContent = visible + ' user' + (visible !== 1 ? 's' : '');
    }

    /* ── Safe HTML injector ──
       Scripts run inside new Function() so every tab reload gets a
       fresh local scope — no global variable collisions on re-click. ── */
    function injectHTML(container, html) {
        const tmp = document.createElement('div');
        tmp.innerHTML = html;
        const scripts = Array.from(tmp.querySelectorAll('script'));
        scripts.forEach(s => s.remove());
        container.innerHTML = tmp.innerHTML;
        container.classList.remove('page-fade-in');
        void container.offsetWidth;
        container.classList.add('page-fade-in');
        scripts.forEach(old => {
            const code = old.textContent || '';
            if (/loadTab\s*\(|loadContent\s*\(|DOMContentLoaded/.test(code)) return;
            try {
                new Function('"use strict";\n' + code)();
            } catch(e) { console.warn('Script init error:', e); }
        });
    }

    /* ── Core content loader (GET) ── */
    async function loadContent(url) {
        const container = document.getElementById('pageContent');
        try {
            const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (res.status === 401 || res.status === 403) {
                window.location.reload();
                return;
            }
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const html = await res.text();
            injectHTML(container, html);
        } catch (err) {
            console.error(err);
            container.innerHTML = `<div class="loading-state">Access Denied or Error loading page.</div>`;
        }
    }

    /* ── Tab navigation ── */
    function loadTab(el, page) {
        if (window.event) window.event.preventDefault();
        document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
        if (el) el.classList.add('active');
        document.getElementById('mainContent').scrollTop = 0;
        const base = pageUrls[page];
        if (!base) return;
        const url = base + (base.includes('?') ? '&' : '?') + 'partial=true';
        loadContent(url);
    }

    /* ── AJAX form submission (handles Create, Edit, Delete, Search) ── */
    document.addEventListener('submit', async function (e) {
        const form = e.target;

        /* ── Search form: GET request ── */
        if (form.classList.contains('search-form')) {
            e.preventDefault();
            const params = new URLSearchParams(new FormData(form)).toString();
            const action = form.getAttribute('action') || '/Books/Products';
            loadContent(`${action}?${params}`);
            return;
        }

        /* ── Book CRUD forms (Create / Edit / Delete): POST via fetch ── */
        if (form.classList.contains('crud-form')) {
            e.preventDefault();
            const action   = form.getAttribute('action') || window.location.pathname;
            const formData = new FormData(form);
            const submitBtn = form.querySelector('[type="submit"]');
            const origLabel = submitBtn ? submitBtn.innerHTML : '';
            if (submitBtn) { submitBtn.disabled = true; submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Saving…'; }
            try {
                const res  = await fetch(action, { method: 'POST', body: formData });
                const html = await res.text();
                if (res.ok && (html.trim() === '' || !html.includes('crud-form'))) {
                    showToast('Done! Changes saved successfully.', 'success');
                    const activeNav = document.querySelector('.nav-item.active') ||
                                      document.querySelector('.nav-item[data-page="products"]');
                    const activePage = activeNav ? activeNav.dataset.page : 'products';
                    loadTab(activeNav, activePage);
                } else if (res.ok && html.includes('crud-form')) {
                    injectHTML(document.getElementById('pageContent'), html);
                    if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = origLabel; }
                } else {
                    document.getElementById('pageContent').innerHTML = html;
                    if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = origLabel; }
                }
            } catch (err) {
                console.error('Form submit error:', err);
                showToast('Network error — please try again.', 'error');
                if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = origLabel; }
            }
        }
    });

    /* ── Initial page load ── */
    window.addEventListener('DOMContentLoaded', () => {
        // If redirected from Register page with ?tab=users, open Users tab + show toast
        const urlParams = new URLSearchParams(window.location.search);
        const tab = urlParams.get('tab');
        const registered = urlParams.get('registered');

        if (tab === 'users') {
            const usersNav = document.querySelector('.nav-item[data-page="users"]');
            if (usersNav) {
                loadTab(usersNav, 'users');
                if (registered === 'true') {
                    setTimeout(() => showToast('User registered successfully!', 'success'), 400);
                }
            }
        } else {
            const first = document.querySelector('.nav-item[data-page="products"]');
            if (first) loadTab(first, 'products');
        }
    });
</script>
</body>
</html>
