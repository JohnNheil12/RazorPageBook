@page
@model DashboardModel
@{
    Layout = "AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<div class="admin-container">

    <main class="main-content">
        <div id="dashboardContent">
            </div>
    </main>

</div>

<style>
    :root {
        --sidebar-w: 280px;
        --lib-dark: #0f141a;
        --lib-gold: #e2b857;
        --lib-bg: #f4f6f8;
        --nav-hover: rgba(255, 255, 255, 0.05);
    }

    /* Layout Structure */
    .admin-container {
        display: flex; /* Critical for side-by-side */
        width: 100%;
        min-height: 100vh;
        background-color: var(--lib-bg);
    }

    /* Sidebar Fix */
    .sidebar {
        width: var(--sidebar-w);
        background-color: var(--lib-dark);
        color: #fff;
        position: fixed;
        height: 100vh;
        left: 0;
        top: 0;
        display: flex;
        flex-direction: column;
        padding: 40px 20px;
        box-sizing: border-box;
        z-index: 1000;
        border-right: 1px solid rgba(255,255,255,0.05);
    }

    /* Header & Logo */
    .sidebar-header { text-align: center; margin-bottom: 40px; }
    .logo-icon { font-size: 2.5rem; color: var(--lib-gold); margin-bottom: 10px; }
    .logo-text { 
        font-family: 'Playfair Display', serif; 
        font-size: 1.25rem; 
        margin: 0; 
        letter-spacing: 0.5px;
    }
    .admin-status {
        font-size: 10px;
        color: var(--lib-gold);
        letter-spacing: 2px;
        border: 1px solid var(--lib-gold);
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        margin-top: 10px;
        opacity: 0.8;
    }

    /* Navigation Menu */
    .nav-menu { flex-grow: 1; }
    .menu-category {
        font-size: 11px;
        text-transform: uppercase;
        color: #4b5563;
        letter-spacing: 1.5px;
        margin: 25px 0 10px 12px;
        font-weight: 700;
    }
    .nav-menu a {
        display: flex;
        align-items: center;
        gap: 14px;
        color: #94a3b8;
        text-decoration: none;
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 14px;
        transition: 0.2s ease;
        margin-bottom: 4px;
    }
    .nav-menu a:hover { background: var(--nav-hover); color: #fff; }
    .nav-menu a.active {
        background: rgba(226, 184, 87, 0.1);
        color: var(--lib-gold);
        border-left: 3px solid var(--lib-gold);
        border-radius: 0 8px 8px 0;
        font-weight: 500;
    }

    /* Footer Exit Link */
    .sidebar-footer { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; }
    .exit-btn { 
        color: #94a3b8; 
        text-decoration: none; 
        font-size: 14px; 
        display: flex; 
        align-items: center; 
        gap: 5px; 
    }
    .exit-btn:hover { color: #fff; }

    /* --- THE CONTENT FIX --- */
    .main-content {
        margin-left:150px;
        flex: 1; 
        padding: 10px; 
        min-height: 100vh;
        background-color: var(--lib-bg);
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
    }
    .inventory-container, .table-responsive {
        width: 100% !important;
    }

    #dashboardContent {
        width: 100%;
     max-width: none; 
        margin: 0; /* Keeps it flush to the left of the main area */
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    function loadPage(pageUrl) {
        fetch(pageUrl)
            .then(response => response.text())
            .then(data => {
                document.getElementById("dashboardContent").innerHTML = data;
            });
    }

    function setActive(el) {
        document.querySelectorAll('.nav-menu a').forEach(a => a.classList.remove('active'));
        el.classList.add('active');
        // Scroll main content to top when switching
        window.scrollTo(0,0);
    }

    // Default load: Inventory
    window.onload = function () {
        loadPage('/Books/Inventory');
    };
</script>