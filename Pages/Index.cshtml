@page
@model IndexModel
@{
    ViewData["Title"] = "The Book Cellar";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<div class="book-banner mb-5">
    @if (User.Identity.IsAuthenticated && User.Identity.Name == "admin")
    {
        <div class="banner-topbar">
            <a asp-page="/Books/Inventory" class="btn btn-banner-inventory">
                <i class="bi bi-archive me-2"></i> Inventory
            </a>
        </div>
    }

    <div class="container h-100 d-flex align-items-center">
        <div class="banner-content">
            <h1 class="display-2 fw-bold text-serif text-white">The Book Cellar.</h1>
            <p class="lead text-white-50">Curate your legacy, one page at a time.</p>
        </div>
    </div>
</div>

<div class="container">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var item in Model.Book)
        {
            <div class="col">
                <div class="book-card-premium">
                    <div class="card-img-container">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1543005120-019f2ef5532a?w=800" : item.ImageUrl)"
                             class="book-img" alt="@item.Title">

                        <div class="floating-badge">@item.YearPublished</div>

                        @if (User.Identity.IsAuthenticated && User.Identity.Name == "admin")
                        {
                            <div class="img-overlay">
                                <a asp-page="/Books/Details" asp-route-id="@item.Id" class="btn btn-glass btn-sm">
                                    <i class="bi bi-eye"></i> Quick View
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="img-overlay">
                                <a asp-page="/Books/Details" asp-route-id="@item.Id" class="btn btn-glass btn-sm">
                                    <i class="bi bi-book-open"></i> View Details
                                </a>
                            </div>
                        }
                    </div>

                    <div class="card-content">
                        <div class="publisher-tag">@item.Publisher</div>
                        <h5 class="book-title">@item.Title</h5>
                        <p class="book-author text-muted">by <span class="text-dark">@item.Author</span></p>

                        @if (User.Identity.IsAuthenticated && User.Identity.Name == "admin")
                        {
                            <div class="action-footer">
                                <a asp-page="/Books/Edit" asp-route-id="@item.Id" class="action-btn edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-page="/Books/Delete" asp-route-id="@item.Id" class="action-btn delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    :root {
        --card-bg: #ffffff;
        --accent: #2d3436;
        --radius: 16px;
    }

    body {
        background-color: #e0e0e0;
        font-family: 'Inter', sans-serif;
    }

    .text-serif {
        font-family: 'Playfair Display', serif;
    }

    /* Hero Banner */
    .book-banner {
        position: relative;
        height: 350px;
        background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?w=1600');
        background-size: cover;
        background-position: center;
        border-radius: 0 0 50px 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    /* Topbar — anchors Inventory to top-right of banner */
    .banner-topbar {
        position: absolute;
        top: 20px;
        right: 30px;
        z-index: 10;
    }

    /* Inventory button */
    .btn-banner-inventory {
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border: 1.5px solid rgba(255,255,255,0.4);
        color: #fff;
        margin-top: 20px;
        font-weight: 600;
        font-size: 0.9rem;
        border-radius: 50px;
        padding: 10px 24px;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

        .btn-banner-inventory:hover {
            background: rgba(255,255,255,0.28);
            border-color: rgba(255,255,255,0.7);
            color: #fff;
            transform: translateY(-2px);
        }

    /* Premium Card Structure */
    .book-card-premium {
        background: var(--card-bg);
        border-radius: var(--radius);
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }

        .book-card-premium:hover {
            transform: translateY(-12px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }

    /* Image Container */
    .card-img-container {
        height: 300px;
        position: relative;
        overflow: hidden;
    }

    .book-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .book-card-premium:hover .book-img {
        transform: scale(1.1);
    }

    /* Overlay & Badges */
    .img-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: 0.3s;
    }

    .book-card-premium:hover .img-overlay {
        opacity: 1;
    }

    .btn-glass {
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        font-weight: 600;
        border-radius: 50px;
        padding: 10px 22px;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

        .btn-glass:hover {
            background: rgba(255,255,255,0.35);
            color: white;
            transform: scale(1.05);
        }

    .floating-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: var(--accent);
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    /* Content Area */
    .card-content {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        background-color: #ffffff;
    }

    .publisher-tag {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #0984e3 !important;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .book-title {
        font-size: 1.2rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
        color: #2d3436 !important;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .book-author {
        color: #636e72 !important;
        font-size: 0.9rem;
    }

    .action-footer {
        margin-top: auto;
        display: flex;
        gap: 10px;
        padding-top: 1rem;
    }

    .action-btn {
        flex: 1;
        text-align: center;
        padding: 8px;
        border-radius: 10px;
        transition: 0.2s;
        text-decoration: none;
        font-size: 1.1rem;
    }

        .action-btn.edit {
            background: #f1f2f6;
            color: #2d3436;
        }

        .action-btn.delete {
            background: #ffeaa7;
            color: #d63031;
        }

        .action-btn.view-details {
            background: #f1f2f6;
            color: #2d3436;
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            border-radius: 50px;
            padding: 10px;
            border: 1.5px solid #e0e0e0;
            transition: all 0.2s;
        }

            .action-btn.view-details:hover {
                background: #2d3436;
                color: #fff;
                border-color: #2d3436;
                transform: scale(1.03);
            }

        .action-btn:hover {
            filter: brightness(0.9);
            transform: scale(1.05);
        }
</style>