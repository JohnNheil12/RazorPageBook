@* Orders.cshtml - DISPLAY ONLY (demo data) - no model required *@
@page "/Orders/Orders"
@{
    Layout = null;
    if (Request.Query["partial"] != "true") {
        Response.Redirect("/Dashboard");
        return;
    }
}

<div class="ord-page">
    <div class="ord-shell">

        <!-- LEFT: Orders List -->
        <div class="ord-list-panel">

            <div class="ord-panel-header">
                <div>
                    <div class="ord-eyebrow"><span class="ord-eyebrow-dot"></span> Order Management</div>
                    <h1 class="ord-title">Customer <span class="ord-title-accent">Orders</span></h1>
                </div>
                <button class="ord-btn-ghost" onclick="alert('Export coming soon!')">
                    <i class="bi bi-download"></i> Export
                </button>
            </div>

            <!-- Stats strip -->
            <div class="ord-stats-strip">
                <div class="ord-stat">
                    <span class="ord-stat-val">8</span>
                    <span class="ord-stat-lbl">Total</span>
                </div>
                <div class="ord-stat">
                    <span class="ord-stat-val" style="color:#d97706;">3</span>
                    <span class="ord-stat-lbl">Pending</span>
                </div>
                <div class="ord-stat">
                    <span class="ord-stat-val" style="color:#2563eb;">2</span>
                    <span class="ord-stat-lbl">Processing</span>
                </div>
                <div class="ord-stat">
                    <span class="ord-stat-val" style="color:#059669;">3</span>
                    <span class="ord-stat-lbl">Completed</span>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="ord-toolbar">
                <div class="ord-search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" id="ordSearch" placeholder="Search orders, customers…" oninput="filterOrders()" />
                </div>
                <select class="ord-filter-sel" id="ordStatusFilter" onchange="filterOrders()">
                    <option value="">All Status</option>
                    <option value="Pending">Pending</option>
                    <option value="Processing">Processing</option>
                    <option value="Shipped">Shipped</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>

            <!-- Order cards -->
            <div class="ord-cards-list" id="ordCardsList">
                <!-- generated by JS from demoOrders -->
            </div>
        </div>

        <!-- RIGHT: Detail Panel -->
        <div class="ord-detail-panel" id="ordDetailPanel">

            <div class="ord-detail-empty" id="ordDetailEmpty">
                <div class="ord-empty-icon"><i class="bi bi-bag-check"></i></div>
                <h3>Select an Order</h3>
                <p>Click any order from the list to view its details</p>
            </div>

            <div class="ord-detail-body" id="ordDetailBody" style="display:none;">

                <div class="ord-detail-header">
                    <div>
                        <div class="ord-detail-num" id="dOrderNum">#ORD-001</div>
                        <div class="ord-detail-date" id="dOrderDate">Jan 1, 2025</div>
                    </div>
                    <div class="ord-detail-header-right">
                        <span class="ord-status-badge" id="dStatusBadge">Pending</span>
                        <button class="ord-btn-ghost ord-btn-sm" onclick="closeOrdDetail()"><i class="bi bi-x-lg"></i></button>
                    </div>
                </div>

                <!-- Timeline -->
                <div class="ord-timeline">
                    <div class="ord-tl-step" data-step="Pending">
                        <div class="ord-tl-dot"><i class="bi bi-clock"></i></div>
                        <span class="ord-tl-label">Pending</span>
                    </div>
                    <div class="ord-tl-conn"></div>
                    <div class="ord-tl-step" data-step="Processing">
                        <div class="ord-tl-dot"><i class="bi bi-gear"></i></div>
                        <span class="ord-tl-label">Processing</span>
                    </div>
                    <div class="ord-tl-conn"></div>
                    <div class="ord-tl-step" data-step="Shipped">
                        <div class="ord-tl-dot"><i class="bi bi-truck"></i></div>
                        <span class="ord-tl-label">Shipped</span>
                    </div>
                    <div class="ord-tl-conn"></div>
                    <div class="ord-tl-step" data-step="Completed">
                        <div class="ord-tl-dot"><i class="bi bi-check-circle"></i></div>
                        <span class="ord-tl-label">Completed</span>
                    </div>
                </div>

                <!-- Customer -->
                <div class="ord-section">
                    <div class="ord-section-title"><i class="bi bi-person-circle"></i> Customer</div>
                    <div class="ord-cust-card">
                        <div class="ord-cust-avatar" id="dCustAvatar">A</div>
                        <div>
                            <div class="ord-cust-name" id="dCustName">—</div>
                            <div class="ord-cust-meta" id="dCustEmail">—</div>
                            <div class="ord-cust-meta" id="dCustPhone">—</div>
                        </div>
                    </div>
                    <div class="ord-address-box" id="dAddress">—</div>
                </div>

                <!-- Items -->
                <div class="ord-section">
                    <div class="ord-section-title"><i class="bi bi-bag"></i> Order Items</div>
                    <div class="ord-items-list" id="dItems"></div>
                </div>

                <!-- Summary -->
                <div class="ord-section">
                    <div class="ord-summary" id="dSummary"></div>
                </div>

                <!-- Update Status -->
                <div class="ord-section">
                    <div class="ord-section-title"><i class="bi bi-pencil-square"></i> Update Status</div>
                    <div class="ord-update-row">
                        <select class="ord-status-select" id="ordStatusSelect">
                            <option value="Pending">Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <button class="ord-btn-update" onclick="updateStatus()">
                            <i class="bi bi-check2"></i> Update
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .ord-page {
        height: 100%;
        --os: #ffffff; --ob: #f8fafc; --obr: #e2e8f0; --obrl: #f1f5f9;
        --ot: #0f172a; --otm: #64748b; --otl: #94a3b8;
        --oa: #1d4ed8;
        --oe: #059669; --oebg: #ecfdf5; --oebr: #a7f3d0;
        --oam: #d97706; --oambg: #fffbeb; --oambr: #fde68a;
        --oro: #e11d48; --orobg: #fff1f2; --orobr: #fecdd3;
        --obl: #2563eb; --oblbg: #eff6ff; --oblbr: #bfdbfe;
        --ov: #7c3aed; --ovbg: #f5f3ff; --ovbr: #ddd6fe;
        --osl: #64748b; --oslbg: #f1f5f9; --oslbr: #e2e8f0;
    }

    .ord-shell { display: flex; height: 100vh; overflow: hidden; }

    /* List panel */
    .ord-list-panel { width: 360px; min-width: 300px; flex-shrink: 0; background: var(--os); border-right: 1px solid var(--obr); display: flex; flex-direction: column; overflow: hidden; }

    .ord-panel-header { display: flex; align-items: flex-start; justify-content: space-between; padding: 22px 18px 14px; border-bottom: 1px solid var(--obr); flex-shrink: 0; gap: 10px; }
    .ord-eyebrow { display: flex; align-items: center; gap: 6px; font-size: 0.63rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--oa); margin-bottom: 3px; }
    .ord-eyebrow-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--oa); display: inline-block; }
    .ord-title { font-family: 'Playfair Display', serif; font-size: 1.45rem; font-weight: 700; color: var(--ot); margin: 0; line-height: 1.2; }
    .ord-title-accent { color: var(--oa); font-style: italic; }

    .ord-btn-ghost { display: inline-flex; align-items: center; gap: 5px; padding: 7px 13px; background: var(--os); color: var(--ot); border: 1.5px solid var(--obr); border-radius: 9px; font-size: 0.78rem; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: background 0.15s; white-space: nowrap; }
    .ord-btn-ghost:hover { background: #f1f5f9; }
    .ord-btn-sm { padding: 5px 9px; font-size: 0.76rem; }

    .ord-stats-strip { display: flex; padding: 10px 18px; gap: 4px; border-bottom: 1px solid var(--obr); flex-shrink: 0; }
    .ord-stat { flex: 1; text-align: center; padding: 7px 2px; }
    .ord-stat-val { display: block; font-size: 1.25rem; font-weight: 700; color: var(--ot); line-height: 1; }
    .ord-stat-lbl { font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--otm); }

    .ord-toolbar { display: flex; gap: 7px; padding: 10px 14px; border-bottom: 1px solid var(--obr); flex-shrink: 0; }
    .ord-search-box { flex: 1; display: flex; align-items: center; gap: 7px; background: var(--ob); border: 1.5px solid var(--obr); border-radius: 9px; padding: 0 11px; height: 36px; }
    .ord-search-box:focus-within { border-color: var(--oa); }
    .ord-search-box i { color: var(--otl); font-size: 0.82rem; }
    .ord-search-box input { flex: 1; border: none; background: transparent; outline: none; font-size: 0.82rem; font-family: 'DM Sans', sans-serif; color: var(--ot); }
    .ord-filter-sel { height: 36px; padding: 0 8px; border: 1.5px solid var(--obr); border-radius: 9px; background: var(--ob); color: var(--ot); font-size: 0.8rem; font-family: 'DM Sans', sans-serif; outline: none; cursor: pointer; }

    .ord-cards-list { flex: 1; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 6px; }
    .ord-cards-list::-webkit-scrollbar { width: 4px; }
    .ord-cards-list::-webkit-scrollbar-thumb { background: var(--obr); border-radius: 4px; }

    /* Order card */
    .ord-card { background: var(--ob); border: 1.5px solid var(--obr); border-radius: 12px; padding: 13px; cursor: pointer; transition: border-color 0.15s, background 0.15s; }
    .ord-card:hover { background: #f0f4ff; border-color: #bfdbfe; }
    .ord-card.selected { background: #eff6ff; border-color: var(--oa); box-shadow: 0 0 0 3px rgba(29,78,216,0.07); }
    .ord-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 7px; }
    .ord-card-num { font-size: 0.83rem; font-weight: 700; color: var(--ot); font-family: monospace; }
    .ord-card-cust { display: flex; align-items: center; gap: 8px; margin-bottom: 7px; }
    .ord-cust-mini-av { width: 24px; height: 24px; border-radius: 7px; background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff; font-size: 0.67rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ord-cust-mini-name { font-size: 0.81rem; color: var(--otm); font-weight: 500; }
    .ord-card-footer { display: flex; align-items: center; justify-content: space-between; }
    .ord-card-date { font-size: 0.7rem; color: var(--otl); display: flex; align-items: center; gap: 4px; }
    .ord-card-total { font-size: 0.86rem; font-weight: 700; color: var(--ot); }

    /* Status badges */
    .ord-status-badge { display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 20px; font-size: 0.68rem; font-weight: 700; text-transform: capitalize; }
    .ord-status-badge.pending    { background: var(--oambg); color: var(--oam); border: 1px solid var(--oambr); }
    .ord-status-badge.processing { background: var(--oblbg); color: var(--obl); border: 1px solid var(--oblbr); }
    .ord-status-badge.shipped    { background: var(--ovbg);  color: var(--ov);  border: 1px solid var(--ovbr);  }
    .ord-status-badge.completed  { background: var(--oebg);  color: var(--oe);  border: 1px solid var(--oebr);  }
    .ord-status-badge.cancelled  { background: var(--orobg); color: var(--oro); border: 1px solid var(--orobr); }

    /* Detail panel */
    .ord-detail-panel { flex: 1; min-width: 0; background: var(--ob); overflow-y: auto; display: flex; flex-direction: column; }
    .ord-detail-panel::-webkit-scrollbar { width: 5px; }
    .ord-detail-panel::-webkit-scrollbar-thumb { background: var(--obr); border-radius: 4px; }

    .ord-detail-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 40px; color: var(--otm); }
    .ord-empty-icon { width: 70px; height: 70px; border-radius: 20px; background: var(--os); border: 1px solid var(--obr); display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: var(--otl); margin: 0 auto 16px; }
    .ord-detail-empty h3 { font-size: 1rem; font-weight: 600; color: var(--ot); margin: 0 0 6px; }
    .ord-detail-empty p { font-size: 0.84rem; margin: 0; }

    .ord-detail-body { padding: 22px; display: flex; flex-direction: column; gap: 14px; }

    .ord-detail-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; background: var(--os); border: 1px solid var(--obr); border-radius: 14px; padding: 18px 22px; border-left: 4px solid var(--oa); }
    .ord-detail-num { font-size: 1.15rem; font-weight: 700; color: var(--ot); font-family: monospace; }
    .ord-detail-date { font-size: 0.76rem; color: var(--otm); margin-top: 3px; }
    .ord-detail-header-right { display: flex; align-items: center; gap: 9px; }

    /* Timeline */
    .ord-timeline { display: flex; align-items: center; background: var(--os); border: 1px solid var(--obr); border-radius: 14px; padding: 16px 18px; }
    .ord-tl-step { display: flex; flex-direction: column; align-items: center; gap: 5px; flex: 0 0 auto; }
    .ord-tl-conn { flex: 1; height: 2px; background: var(--obr); margin: 0 6px; margin-bottom: 20px; transition: background 0.3s; }
    .ord-tl-conn.active { background: var(--oa); }
    .ord-tl-dot { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--obr); background: var(--ob); color: var(--otl); font-size: 0.82rem; display: flex; align-items: center; justify-content: center; transition: all 0.25s; }
    .ord-tl-dot.active { background: var(--oa); border-color: var(--oa); color: #fff; box-shadow: 0 0 0 4px rgba(29,78,216,0.1); }
    .ord-tl-dot.done   { background: var(--oe); border-color: var(--oe); color: #fff; }
    .ord-tl-label { font-size: 0.62rem; font-weight: 600; text-transform: uppercase; color: var(--otm); white-space: nowrap; }
    .ord-tl-step.active .ord-tl-label { color: var(--oa); }
    .ord-tl-step.done   .ord-tl-label { color: var(--oe); }

    /* Sections */
    .ord-section { background: var(--os); border: 1px solid var(--obr); border-radius: 14px; padding: 16px 18px; }
    .ord-section-title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--otm); margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }

    .ord-cust-card { display: flex; align-items: center; gap: 13px; margin-bottom: 11px; }
    .ord-cust-avatar { width: 42px; height: 42px; border-radius: 12px; background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff; font-size: 1.05rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ord-cust-name { font-size: 0.9rem; font-weight: 700; color: var(--ot); }
    .ord-cust-meta { font-size: 0.76rem; color: var(--otm); }
    .ord-address-box { font-size: 0.81rem; color: var(--otm); padding: 9px 13px; background: var(--ob); border-radius: 8px; border: 1px solid var(--obr); }

    .ord-items-list { display: flex; flex-direction: column; gap: 9px; }
    .ord-item-row { display: flex; align-items: center; gap: 11px; padding: 9px 11px; background: var(--ob); border-radius: 9px; border: 1px solid var(--obr); }
    .ord-item-thumb { width: 38px; height: 52px; border-radius: 6px; background: var(--obr); overflow: hidden; flex-shrink: 0; border: 1px solid var(--obr); }
    .ord-item-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .ord-item-info { flex: 1; min-width: 0; }
    .ord-item-title { font-size: 0.83rem; font-weight: 600; color: var(--ot); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ord-item-author { font-size: 0.7rem; color: var(--otm); }
    .ord-item-meta { text-align: right; flex-shrink: 0; }
    .ord-item-qty { font-size: 0.7rem; color: var(--otm); }
    .ord-item-price { font-size: 0.86rem; font-weight: 700; color: var(--ot); }

    .ord-summary { display: flex; flex-direction: column; gap: 9px; }
    .ord-sum-row { display: flex; justify-content: space-between; font-size: 0.84rem; color: var(--otm); padding: 3px 0; }
    .ord-sum-row.total { border-top: 1px solid var(--obr); padding-top: 11px; margin-top: 2px; font-size: 0.93rem; font-weight: 700; color: var(--ot); }

    .ord-update-row { display: flex; gap: 8px; }
    .ord-status-select { flex: 1; height: 40px; padding: 0 12px; border: 1.5px solid var(--obr); border-radius: 9px; background: var(--ob); color: var(--ot); font-size: 0.84rem; font-family: 'DM Sans', sans-serif; outline: none; cursor: pointer; }
    .ord-status-select:focus { border-color: var(--oa); }
    .ord-btn-update { display: inline-flex; align-items: center; gap: 6px; padding: 0 18px; height: 40px; background: var(--oa); color: #fff; border: none; border-radius: 9px; font-size: 0.83rem; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: background 0.15s; white-space: nowrap; }
    .ord-btn-update:hover { background: #1e40af; }

    @@media (max-width: 900px) {
        .ord-shell { flex-direction: column; height: auto; }
        .ord-list-panel { width: 100%; min-width: unset; border-right: none; border-bottom: 1px solid var(--obr); max-height: 50vh; }
        .ord-detail-panel { min-height: 50vh; }
    }
    @@media (max-width: 480px) {
        .ord-detail-body { padding: 12px; }
        .ord-tl-label { display: none; }
    }
</style>

