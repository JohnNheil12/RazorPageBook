            customerPhone: "+63 921 778 9900", address: "89 Leon Kilat St., Cebu City, Cebu 6000",
            orderDate: "March 27, 2025 · 1:55 PM",
            subtotal: 1800.00, shipping: 0.00, tax: 216.00, total: 2016.00,
            items: [
                { title: "Rich Dad Poor Dad", author: "Robert Kiyosaki", qty: 2, price: 480.00, image: "" },
                { title: "Think and Grow Rich", author: "Napoleon Hill", qty: 1, price: 840.00, image: "" }
            ]
        }
    ];

    let currentOrdId = null;

    function renderCards() {
        const list = document.getElementById('ordCardsList');
        list.innerHTML = demoOrders.map(o => `
            <div class="ord-card" data-id="${o.id}" data-status="${o.status}"
                 data-customer="${o.customerName.toLowerCase()}"
                 data-ordernum="${o.orderNumber.toLowerCase()}"
                 onclick="selectOrd(this, ${o.id})">
                <div class="ord-card-top">
                    <div class="ord-card-num">#${o.orderNumber}</div>
                    <span class="ord-status-badge ${o.status.toLowerCase()}">${o.status}</span>
                </div>
                <div class="ord-card-cust">
                    <div class="ord-cust-mini-av">${o.customerName[0].toUpperCase()}</div>
                    <span class="ord-cust-mini-name">${o.customerName}</span>
                </div>
                <div class="ord-card-footer">
                    <span class="ord-card-date"><i class="bi bi-clock"></i> ${o.orderDate.split('·')[0].trim()}</span>
                    <span class="ord-card-total">₱ ${o.total.toLocaleString('en-PH', {minimumFractionDigits:2})}</span>
                </div>
            </div>
        `).join('');
    }

    function selectOrd(el, ordId) {
        document.querySelectorAll('.ord-card').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        currentOrdId = ordId;

        const o = demoOrders.find(x => x.id === ordId);
        if (!o) return;

        document.getElementById('ordDetailEmpty').style.display = 'none';
        document.getElementById('ordDetailBody').style.display = 'flex';

        document.getElementById('dOrderNum').textContent = '#' + o.orderNumber;
        document.getElementById('dOrderDate').textContent = o.orderDate;

        const badge = document.getElementById('dStatusBadge');
        badge.textContent = o.status;
        badge.className = 'ord-status-badge ' + o.status.toLowerCase();

        // Timeline
        const curIdx = statusOrder.indexOf(o.status);
        document.querySelectorAll('.ord-tl-step').forEach((step, i) => {
            const idx = statusOrder.indexOf(step.dataset.step);
            const dot = step.querySelector('.ord-tl-dot');
            step.classList.remove('active', 'done');
            dot.classList.remove('active', 'done');
            if (idx < curIdx) { step.classList.add('done'); dot.classList.add('done'); }
            else if (idx === curIdx) { step.classList.add('active'); dot.classList.add('active'); }
        });
        document.querySelectorAll('.ord-tl-conn').forEach((c, i) => {
            c.classList.toggle('active', i < curIdx);
        });

        // Customer
        document.getElementById('dCustAvatar').textContent = o.customerName[0].toUpperCase();
        document.getElementById('dCustName').textContent = o.customerName;
        document.getElementById('dCustEmail').textContent = o.customerEmail;
        document.getElementById('dCustPhone').textContent = o.customerPhone;
        document.getElementById('dAddress').textContent = o.address;

        // Items
        document.getElementById('dItems').innerHTML = o.items.map(item => `
            <div class="ord-item-row">
                <div class="ord-item-thumb">
                    <img src="https://via.placeholder.com/38x52?text=📖" alt="${item.title}" />
                </div>
                <div class="ord-item-info">
                    <div class="ord-item-title">${item.title}</div>
                    <div class="ord-item-author">${item.author}</div>
                </div>
                <div class="ord-item-meta">
                    <div class="ord-item-qty">x${item.qty}</div>
                    <div class="ord-item-price">₱ ${(item.price * item.qty).toFixed(2)}</div>
                </div>
            </div>
        `).join('');

        // Summary
        document.getElementById('dSummary').innerHTML = `
            <div class="ord-sum-row"><span>Subtotal</span><span>₱ ${o.subtotal.toFixed(2)}</span></div>
            <div class="ord-sum-row"><span>Shipping</span><span>${o.shipping === 0 ? 'Free' : '₱ ' + o.shipping.toFixed(2)}</span></div>
            <div class="ord-sum-row"><span>Tax (12%)</span><span>₱ ${o.tax.toFixed(2)}</span></div>
            <div class="ord-sum-row total"><span>Total</span><span>₱ ${o.total.toFixed(2)}</span></div>
        `;

        document.getElementById('ordStatusSelect').value = o.status;
    }

    function closeOrdDetail() {
        document.getElementById('ordDetailEmpty').style.display = 'flex';
        document.getElementById('ordDetailBody').style.display = 'none';
        document.querySelectorAll('.ord-card').forEach(c => c.classList.remove('selected'));
        currentOrdId = null;
    }

    function updateStatus() {
        if (!currentOrdId) return;
        const newStatus = document.getElementById('ordStatusSelect').value;
        const o = demoOrders.find(x => x.id === currentOrdId);
        if (!o) return;
        o.status = newStatus;

        // Re-render card
        const card = document.querySelector(`.ord-card[data-id="${currentOrdId}"]`);
        if (card) {
            card.querySelector('.ord-status-badge').textContent = newStatus;
            card.querySelector('.ord-status-badge').className = 'ord-status-badge ' + newStatus.toLowerCase();
            card.dataset.status = newStatus;
        }
        // Re-render detail
        selectOrd(document.querySelector(`.ord-card[data-id="${currentOrdId}"]`), currentOrdId);
    }

    function filterOrders() {
        const q = document.getElementById('ordSearch').value.toLowerCase();
        const s = document.getElementById('ordStatusFilter').value.toLowerCase();
        document.querySelectorAll('.ord-card').forEach(card => {
            const matchQ = !q || card.dataset.customer.includes(q) || card.dataset.ordernum.includes(q);
            const matchS = !s || card.dataset.status.toLowerCase() === s;
            card.style.display = (matchQ && matchS) ? '' : 'none';
        });
    }

    // Init
    renderCards();
</script>
