                        <div>
                            <div class="feat-title">Admin Only</div>
                            <div class="feat-desc">Only administrators can create new accounts</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="brand-footer">© 2025 The Book Cellar · All rights reserved</div>
        </div>

    <!-- ── RIGHT FORM PANEL ── -->
    <div class="form-panel">
        <div class="form-inner">
            <div class="auth-card">

                <div class="card-accent-line"></div>

                <div class="auth-card-header">
                    @if (isForced)
                    {
                        <div class="welcome-badge forced"><i class="bi bi-exclamation-circle"></i> Action Required</div>
                    }
                    <h2 class="auth-title">Set your<br>new password</h2>
                    <p class="auth-sub">
                        @if (isForced)
                        {
                            <span>You must create a new password before accessing the dashboard.</span>
                        }
                        else
                        {
                            <span>Enter a new password below. You'll use it the next time you sign in.</span>
                        }
                    </p>
                </div>

                <form method="post">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="err-summary-box">
                            <ul>
                                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@err.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }

                    <!-- Current Password -->
                    <div class="field-block">
                        <label class="field-label" for="CurrentPassword">
                            <i class="bi bi-lock-fill"></i> Current Password
                        </label>
                        <div class="input-wrap">
                            <input class="field-input" type="password" id="CurrentPassword" name="CurrentPassword"
                                   autocomplete="current-password" placeholder="Enter current password" required />
                            <button type="button" class="eye-btn" onclick="togglePw('CurrentPassword','eye0')" aria-label="Toggle current password">
                                <i class="bi bi-eye" id="eye0"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="field-err"></span>
                    </div>

                    <!-- New Password -->
                    <div class="field-block" style="margin-top: 24px;">
                        <label class="field-label" for="NewPassword">
                            <i class="bi bi-lock"></i> New Password
                        </label>
                        <div class="input-wrap">
                            <input class="field-input" type="password" id="NewPassword" name="NewPassword"
                                   autocomplete="new-password" placeholder="Enter new password"
                                   oninput="checkStrength(this.value)" required />
                            <button type="button" class="eye-btn" onclick="togglePw('NewPassword','eye1')" aria-label="Toggle password">
                                <i class="bi bi-eye" id="eye1"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="field-err"></span>

                        <!-- Strength meter -->
                        <div class="strength-wrap">
                            <div class="strength-track">
                                <div class="strength-fill" id="strengthFill"></div>
                            </div>
                            <div class="strength-row">
                                <span class="strength-label">Password strength</span>
                                <span class="strength-status" id="strengthTxt">Enter a password</span>
                            </div>
                        </div>
                    </div>

                    <!-- Requirements -->
                    <div class="req-list">
                        <div class="req-item" id="req-len"><i class="bi bi-circle"></i> 8+ characters</div>
                        <div class="req-item" id="req-upper"><i class="bi bi-circle"></i> Uppercase letter</div>
                        <div class="req-item" id="req-num"><i class="bi bi-circle"></i> Number</div>
                        <div class="req-item" id="req-special"><i class="bi bi-circle"></i> Special character</div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="field-block" style="margin-top: 24px;">
                        <label class="field-label" for="ConfirmPassword">
                            <i class="bi bi-lock-fill"></i> Confirm Password
                        </label>
                        <div class="input-wrap">
                            <input class="field-input" type="password" id="ConfirmPassword" name="ConfirmPassword"
                                   autocomplete="new-password" placeholder="Re-enter your password"
                                   oninput="checkMatch()" required />
                            <button type="button" class="eye-btn" onclick="togglePw('ConfirmPassword','eye2')" aria-label="Toggle confirm password">
                                <i class="bi bi-eye" id="eye2"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="field-err"></span>
                        <div class="match-hint" id="matchHint"></div>
                    </div>

                    <div class="button-group">
                        <button type="submit" class="btn-submit" id="submitBtn">
                            <i class="bi bi-check-circle"></i>
                            <span>Save Password &amp; Continue</span>
                        </button>
                        <a href="/Dashboard/Dashboard" class="btn-back">
                            <i class="bi bi-box-arrow-left"></i> Back to Home
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>

</div>

<script>
    function togglePw(id, iconId) {
        const inp = document.getElementById(id);
        const icon = document.getElementById(iconId);
        const hide = inp.type === 'password';
        inp.type = hide ? 'text' : 'password';
        icon.className = hide ? 'bi bi-eye-slash' : 'bi bi-eye';
    }

    function checkStrength(val) {
        const fill = document.getElementById('strengthFill');
        const txt  = document.getElementById('strengthTxt');

        const reqs = {
            len:     val.length >= 8,
            upper:   /[A-Z]/.test(val),
            num:     /[0-9]/.test(val),
            special: /[^A-Za-z0-9]/.test(val),
        };

        // Update requirement indicators
        setReq('req-len',     reqs.len);
        setReq('req-upper',   reqs.upper);
        setReq('req-num',     reqs.num);
        setReq('req-special', reqs.special);

        const score = Object.values(reqs).filter(Boolean).length;
        const map = [
            { w: '0%',   bg: '#e5e0d6', lbl: 'Enter a password', c: '#9ca3af' },
            { w: '25%',  bg: '#ef4444', lbl: 'Too weak',          c: '#ef4444' },
            { w: '50%',  bg: '#f97316', lbl: 'Fair',              c: '#f97316' },
            { w: '75%',  bg: '#eab308', lbl: 'Good',              c: '#ca8a04' },
            { w: '100%', bg: '#22c55e', lbl: 'Strong ✓',          c: '#16a34a' },
        ];
        const m = map[score];
        fill.style.width      = m.w;
        fill.style.background = m.bg;
        txt.textContent       = m.lbl;
        txt.style.color       = m.c;
        checkMatch();
    }

    function setReq(id, met) {
        const el = document.getElementById(id);
        el.className = 'req-item' + (met ? ' met' : '');
        el.querySelector('i').className = met ? 'bi bi-check-circle-fill' : 'bi bi-circle';
    }

    function checkMatch() {
        const pw  = document.getElementById('NewPassword').value;
        const cpw = document.getElementById('ConfirmPassword').value;
        const hint = document.getElementById('matchHint');
        if (!cpw) { hint.className = 'match-hint'; return; }
        const ok = pw === cpw;
        hint.className = 'match-hint show ' + (ok ? 'ok' : 'fail');
        hint.innerHTML = ok
            ? '<i class="bi bi-check-circle-fill"></i> Passwords match'
            : '<i class="bi bi-x-circle-fill"></i> Passwords do not match';
    }
</script>

