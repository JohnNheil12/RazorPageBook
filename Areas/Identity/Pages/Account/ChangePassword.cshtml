        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.72rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 1px;
        padding: 5px 12px; border-radius: 20px;
        margin-bottom: 14px;
    }
    .welcome-badge.forced {
        background: #fff7ed;
        border: 1px solid rgba(234,179,8,0.35);
        color: #92400e;
    }
    .welcome-badge.voluntary {
        background: #f0fdf4;
        border: 1px solid rgba(34,197,94,0.3);
        color: #166534;
    }

    .auth-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.3rem; font-weight: 700;
        color: var(--text-main);
        line-height: 1.1; letter-spacing: -0.5px;
        margin-bottom: 8px;
    }

    .auth-sub { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; }

    form { padding: 0 40px 36px; }

    /* ── FIELDS ── */
    .field-block { margin-bottom: 6px; }

    .field-label {
        display: flex; align-items: center; gap: 7px;
        font-size: 0.78rem; font-weight: 600;
        color: var(--text-main); margin-bottom: 8px;
        text-transform: uppercase; letter-spacing: 0.5px;
    }
    .field-label i { color: var(--gold); }

    .input-wrap { position: relative; }
    .field-input {
        width: 100%; padding: 14px 52px 14px 18px;
        border: 1.5px solid var(--border);
        background: var(--paper); border-radius: 12px;
        font-family: 'Jost', sans-serif;
        font-size: 0.93rem; color: var(--text-main);
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        box-sizing: border-box;
    }
    .field-input::placeholder { color: #bdb4a8; }
    .field-input:focus {
        outline: none; border-color: var(--gold);
        background: #fffdf7;
        box-shadow: 0 0 0 4px var(--gold-dim);
    }
     input::-ms-reveal,
    input::-ms-clear {
        display: none;
    }

    input[type="password"]::-webkit-credentials-auto-fill-button,
    input[type="text"]::-webkit-credentials-auto-fill-button {
        display: none;
    }

    .eye-btn {
        position: absolute; right: 14px; top: 50%;
        transform: translateY(-50%);
        background: none; border: none;
        color: #bdb4a8; cursor: pointer;
        font-size: 1rem; padding: 4px;
        transition: color 0.15s;
    }
    .eye-btn:hover { color: var(--gold); }

    /* ── STRENGTH METER ── */
    .strength-wrap { margin-top: 12px; }
    .strength-track {
        height: 5px;
        background: #f0ece6;
        border-radius: 10px; overflow: hidden;
    }
    .strength-fill {
        height: 100%; width: 0;
        border-radius: 10px;
        transition: width 0.4s cubic-bezier(0.34,1.56,0.64,1), background 0.3s;
    }
    .strength-row {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 6px;
    }
    .strength-label { font-size: 0.72rem; color: var(--text-muted); }
    .strength-status { font-size: 0.72rem; font-weight: 600; color: var(--text-muted); transition: color 0.3s; }

    /* ── REQUIREMENTS ── */
    .req-list {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 8px; margin-bottom: 4px;
        background: #faf7f2;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 14px 16px;
    }
    .req-item {
        display: flex; align-items: center; gap: 7px;
        font-size: 0.78rem; color: #bdb4a8;
        transition: color 0.25s;
    }
    .req-item i { font-size: 0.72rem; transition: color 0.25s; }
    .req-item.met { color: #16a34a; }
    .req-item.met i { color: #22c55e; }

    /* ── MATCH HINT ── */
    .match-hint {
        display: flex; align-items: center; gap: 6px;
        font-size: 0.78rem; margin-top: 8px;
        opacity: 0; transition: opacity 0.2s;
    }
    .match-hint.show { opacity: 1; }
    .match-hint.ok   { color: #16a34a; }
    .match-hint.fail { color: var(--error); }

    /* ── ERRORS ── */
    .err-summary-box {
        background: var(--error-bg);
        border: 1px solid rgba(192,57,43,0.2);
        border-left: 3px solid var(--error);
        padding: 14px 16px; border-radius: 10px;
        margin-bottom: 20px;
    }
    .err-summary-box ul { list-style: none; padding: 0; margin: 0; }
    .err-summary-box li {
        color: var(--error); font-size: 0.85rem;
        display: flex; align-items: center; gap: 8px; padding: 2px 0;
    }
    .err-summary-box li::before { content: "\F333"; font-family: "bootstrap-icons"; }
    .field-err { color: var(--error); font-size: 0.78rem; margin-top: 6px; display: block; }

    /* ── BUTTONS ── */
    .button-group { display: flex; flex-direction: column; gap: 14px; margin-top: 28px; }

    .btn-submit {
        width: 100%; padding: 16px 24px;
        background: linear-gradient(135deg, var(--charcoal) 0%, var(--charcoal-2) 100%);
        color: #fff; border: none; border-radius: 12px;
        font-family: 'Jost', sans-serif;
        font-size: 0.95rem; font-weight: 600;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center; gap: 10px;
        letter-spacing: 0.3px;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 16px rgba(26,28,30,0.18);
        position: relative; overflow: hidden;
    }
    .btn-submit::after {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(135deg, rgba(201,168,76,0.18) 0%, transparent 60%);
        opacity: 0; transition: opacity 0.3s;
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,28,30,0.22); }
    .btn-submit:hover::after { opacity: 1; }
    .btn-submit:active { transform: translateY(0); }

    .btn-back {
        text-align: center; text-decoration: none;
        color: var(--text-muted); font-size: 0.87rem; font-weight: 500;
        display: flex; align-items: center; justify-content: center; gap: 6px;
        transition: color 0.2s; padding: 6px;
    }
    .auth-shell {
    display: flex;
    min-height: 100vh;
    width: 100vw; /* Hard-force the shell to span the whole screen width */
    overflow: hidden; /* Recommended to prevent accidental side-scrolling */
}

    .btn-back:hover { color: var(--gold); }
    .form-panel {
    flex: 1 1 50%; /* Grow to equal size, shrink if needed, with a 50% base */
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--paper); /* The cream color you want to see */
    padding: 48px 40px;
    /* --- CRITICAL ADDITIONS --- */
    min-width: 50vw; /* Hard-force this panel to occupy the other half of the viewport width */
}

    /* ── ANIMATIONS ── */
    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes cardReveal {
        from { opacity: 0; transform: translateY(24px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    @@keyframes bloomPulse {
        from { transform: scale(1); opacity: 0.8; }
        to   { transform: scale(1.12); opacity: 1; }
    }

    @@media (max-width: 960px) {
        .brand-panel { display: none; }
        .auth-shell { background: var(--paper); }
        .form-panel { background: var(--paper); }
    }
    @@media (max-width: 480px) {
        .form-panel { padding: 24px 16px; }
        .auth-card-header { padding: 24px 20px 18px; }
        form { padding: 0 20px 24px; }
        .auth-title { font-size: 2rem; }
        .req-list { grid-template-columns: 1fr; }
    }
</style>

</body>
</html>
