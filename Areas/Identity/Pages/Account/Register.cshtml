@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="glass-wrapper-left">
    <div class="glass-card">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h1 class="login-header">@ViewData["Title"]</h1>
            <p class="login-subheader">Create a new account for The Book Cellar.</p>
            <hr class="divider" />

            <div asp-validation-summary="ModelOnly" class="text-danger small" role="alert"></div>

            @* Email Field *@
            <div class="input-group-custom">
                <label asp-for="Input.Email">EMAIL</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            @* Password Field *@
            <div class="input-group-custom">
                <label asp-for="Input.Password">PASSWORD</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Min. 6 characters" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            @* Confirm Password Field *@
            <div class="input-group-custom">
                <label asp-for="Input.ConfirmPassword">CONFIRM PASSWORD</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Re-type password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            @* Registration Button - Styled like your 'Create Record' button *@
            <button id="registerSubmit" type="submit" class="btn-glass-primary w-100">Register Account</button>

            <div class="login-footer mt-3">
                <p class="small text-muted">Already have an account? <a asp-page="./Login">Log in here</a></p>
            </div>
        </form>

        @* External Services Section *@
        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="external-section mt-4">
                <p class="small text-muted">Or sign up with</p>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="social-grid">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn-social" name="provider" value="@provider.Name" title="Register using your @provider.DisplayName account">
                                @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<style>
    /* Container for Left Alignment over Background */
    .glass-wrapper-left {
        min-height: 85vh;
        display: flex;
        justify-content: flex-start;
        align-items: center;
        padding-left: 8%; /* Adjust for your preference */
        background-color: transparent;
    }

    /* Glassmorphism Card Style */
    .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 28px;
        padding: 40px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

        .glass-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.12);
        }

    /* Custom Input Styling to match 'New Entry' Fields */
    .input-group-custom label {
        display: block;
        font-weight: 700;
        font-size: 0.75rem;
        color: #4a4a4a;
        margin-bottom: 6px;
        letter-spacing: 0.05rem;
    }

    .input-group-custom input {
        width: 100%;
        padding: 12px 15px;
        border-radius: 12px;
        border: 1px solid rgba(0, 0, 0, 0.1);
        background: rgba(255, 255, 255, 0.5);
        margin-bottom: 5px;
        transition: 0.3s;
    }

        .input-group-custom input:focus {
            outline: none;
            border-color: #53c8ed;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(83, 200, 237, 0.1);
        }

    /* Primary Button (Bright Blue from your uploaded image) */
    .btn-glass-primary {
        background-color: #53c8ed; /* Matching image_3f4377.png blue */
        color: white;
        border: none;
        padding: 14px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-glass-primary:hover {
            background-color: #3ebce4;
            filter: brightness(1.05);
        }
</style>