@page
@model RazorPageBooks.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
    ViewData["HideNav"] = true;
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="auth-shell">
    <div class="brand-panel">
        <div class="brand-inner">
            <div class="brand-logo">
                <i class="bi bi-book-half"></i>
            </div>
            <h1 class="brand-name">The Book Cellar</h1>
            <p class="brand-tagline">Where every page turns into a new discovery. Sign in to manage your collection.</p>
            <div class="brand-divider"></div>
            <div class="brand-features">
                <div class="brand-feature">
                    <div class="feature-icon-wrap"><i class="bi bi-bar-chart-line"></i></div>
                    <div>
                        <div class="feature-title">Real-time Dashboard</div>
                        <div class="feature-desc">Monitor inventory and sales at a glance</div>
                    </div>
                </div>
                <div class="brand-feature">
                    <div class="feature-icon-wrap"><i class="bi bi-shield-lock"></i></div>
                    <div>
                        <div class="feature-title">Role-Based Access</div>
                        <div class="feature-desc">Admin and Staff permissions built in</div>
                    </div>
                </div>
                <div class="brand-feature">
                    <div class="feature-icon-wrap"><i class="bi bi-collection"></i></div>
                    <div>
                        <div class="feature-title">Full CRUD Control</div>
                        <div class="feature-desc">Add, edit, and remove books instantly</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-panel">
        <div class="form-inner">
            <div class="auth-card @(ViewData.ModelState.IsValid ? "" : "shake-error")">
                <div class="auth-card-header">
                    <h2 class="auth-title">Welcome back</h2>
                    <p class="auth-sub">Sign in to your dashboard to continue</p>
                </div>

                <form id="account" method="post" novalidate>
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div asp-validation-summary="ModelOnly" class="err-summary-box" role="alert"></div>

                    <div class="field-block">
                        <label asp-for="Input.UsernameOrEmail" class="field-label">
                            <i class="bi bi-person-circle"></i> Email
                        </label>
                        <input asp-for="Input.UsernameOrEmail" class="field-input" placeholder="e.g. admin@bookcellar.com" />
                        <span asp-validation-for="Input.UsernameOrEmail" class="field-err"></span>
                    </div>

                    <div class="field-block">
                        <label asp-for="Input.Password" class="field-label">
                            <i class="bi bi-lock"></i> Password
                        </label>
                        <div class="input-wrap">
                            <input asp-for="Input.Password" class="field-input" id="pw-input" type="password" placeholder="Enter password" />
                            <button type="button" class="eye-btn" onclick="togglePw('pw-input','eye1')">
                                <i class="bi bi-eye" id="eye1"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="field-err"></span>
                    </div>

                    <div class="form-row-between">
                        <label class="remember-label">
                            <input asp-for="Input.RememberMe" type="checkbox" />
                            <span>Remember me</span>
                        </label>
                        <a asp-page="./ForgotPassword" class="forgot-link">Forgot password?</a>
                    </div>

                    <div class="button-group">
                        <button type="submit" class="btn-submit">
                            <i class="bi bi-box-arrow-in-right"></i> Sign In
                        </button>
                        <div class="cancel-container">
                            <a href="/" class="btn-ghost-cancel">
                                <i class="bi bi-arrow-left"></i> Back to Home
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePw(inputId, iconId) {
            const inp = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            const show = inp.type === 'password';
            inp.type = show ? 'text' : 'password';
            icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
    </script>
}

<style>
    :root {
        --lib-gold: #b08d57;
        --lib-charcoal: #1e2124;
        --lib-paper: #fdfcfb;
        --lib-border: #e2e8f0;
        --lib-accent-light: rgba(176, 141, 87, 0.1);
        --lib-error: #dc2626;
        --lib-error-bg: #fff5f5;
    }

    body { margin: 0; overflow-x: hidden; }

    .auth-shell {
        display: flex;
        min-height: 100vh;
        background-color: #f8fafc;
        font-family: 'DM Sans', sans-serif;
    }

    /* ── LEFT PANEL ── */
    .brand-panel {
        flex: 1.2;
        background: linear-gradient(135deg, rgba(30, 33, 36, 0.9) 0%, rgba(30, 33, 36, 0.7) 100%), url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=2000') center/cover;
        display: flex; align-items: center; justify-content: center; padding: 80px; color: #ffffff;
    }

    .brand-inner { max-width: 500px; animation: fadeIn 0.8s ease-out; }
    .brand-logo { font-size: 2.5rem; color: var(--lib-gold); margin-bottom: 1rem; }
    .brand-name { font-family: 'Playfair Display', serif; font-size: 4rem; font-weight: 700; margin: 0; letter-spacing: -0.5px; }
    .brand-tagline { font-size: 1.1rem; opacity: 0.85; line-height: 1.6; margin-top: 10px; font-weight: 300; }
    .brand-divider { width: 50px; height: 2px; background: var(--lib-gold); margin: 40px 0; }
    .brand-feature { display: flex; align-items: center; gap: 20px; margin-bottom: 30px; }
    .feature-icon-wrap { width: 48px; height: 48px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--lib-gold); font-size: 1.2rem; }
    .feature-title { font-weight: 600; font-size: 1.05rem; }
    .feature-desc { font-size: 0.9rem; opacity: 0.7; }

    /* ── RIGHT PANEL ── */
    .form-panel { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px; }
    .form-inner { width: 100%; max-width: 440px; }
    .auth-card { background: var(--lib-paper); padding: 50px; border-radius: 16px; border: 1px solid var(--lib-border); box-shadow: 0 20px 50px rgba(0,0,0,0.05); transition: border-color 0.3s ease; }
    .auth-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: var(--lib-charcoal); margin-bottom: 8px; }
    .auth-sub { color: #64748b; font-size: 0.95rem; margin-bottom: 35px; }

    /* ── INPUTS ── */
    .field-block { margin-bottom: 24px; }
    .field-label { font-size: 0.85rem; font-weight: 600; color: var(--lib-charcoal); margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
    .input-wrap { position: relative; }
    .field-input { width: 100%; padding: 14px 16px; border: 1.5px solid var(--lib-border); background: #ffffff; border-radius: 10px; font-family: inherit; font-size: 0.95rem; transition: all 0.2s ease; box-sizing: border-box; }
    .field-input:focus { outline: none; border-color: var(--lib-gold); box-shadow: 0 0 0 4px var(--lib-accent-light); }
    .eye-btn { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer; padding: 5px; }

    /* ── ERROR STYLING ── */
    .err-summary-box:not(:empty) {
        background: var(--lib-error-bg);
        border-left: 4px solid var(--lib-error);
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
    }
    .err-summary-box ul { list-style: none; padding: 0; margin: 0; }
    .err-summary-box li { color: #991b1b; font-size: 0.88rem; display: flex; align-items: center; gap: 8px; }
    .err-summary-box li::before { content: "\F333"; font-family: "bootstrap-icons"; font-weight: bold; }
    .field-err { color: var(--lib-error); font-size: 0.78rem; margin-top: 5px; display: block; }

    /* ── BUTTONS ── */
    .button-group { display: flex; flex-direction: column; gap: 16px; margin-top: 10px; }
    .btn-submit { width: 100%; padding: 16px; background: var(--lib-charcoal); color: #ffffff; border: none; border-radius: 10px; font-weight: 600; font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: all 0.3s ease; }
    .btn-submit:hover { background: #33383f; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }

    .cancel-container { text-align: center; }
    .btn-ghost-cancel { text-decoration: none; color: #94a3b8; font-size: 0.9rem; font-weight: 500; display: inline-flex; align-items: center; gap: 6px; transition: all 0.2s ease; padding: 5px 10px; }
    .btn-ghost-cancel:hover { color: var(--lib-gold); transform: translateX(-4px); }

    /* ── EXTRAS ── */
    .form-row-between { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; font-size: 0.88rem; }
    .remember-label { display: flex; align-items: center; gap: 8px; cursor: pointer; color: #475569; }
    .forgot-link { color: var(--lib-gold); text-decoration: none; font-weight: 600; }
    .forgot-link:hover { text-decoration: underline; }

    /* ── ANIMATIONS ── */
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-8px); } 50% { transform: translateX(8px); } 75% { transform: translateX(-4px); } }
    .shake-error { animation: shake 0.4s ease-in-out; border-color: #f87171 !important; }

    @@media (max-width: 992px) { .brand-panel { display: none; } .auth-shell { background: #fff; } }
</style>