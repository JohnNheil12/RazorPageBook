                <rect x="332" y="163" width="20" height="65" rx="2" fill="#1a3520"/>
                <rect x="332" y="163" width="4" height="65" fill="#122818"/>
                <rect x="337" y="175" width="11" height="1.5" rx="1" fill="rgba(100,200,130,0.4)"/>
                <rect x="337" y="180" width="7" height="1" rx="1" fill="rgba(100,200,130,0.25)"/>

                <!-- B11 - rose/pink dusty -->
                <rect x="354" y="172" width="15" height="56" rx="2" fill="#6a2c38"/>
                <rect x="354" y="172" width="3" height="56" fill="#52222c"/>
                <rect x="358" y="182" width="7" height="1" rx="1" fill="rgba(255,180,190,0.4)"/>

                <!-- B12 - caramel -->
                <rect x="371" y="165" width="18" height="63" rx="2" fill="#7a4a18"/>
                <rect x="371" y="165" width="3.5" height="63" fill="#5c3810"/>
                <rect x="376" y="177" width="9" height="1.5" rx="1" fill="rgba(255,220,150,0.5)"/>
                <rect x="376" y="182" width="6" height="1" rx="1" fill="rgba(255,220,150,0.3)"/>

                <!-- B13 - slate medium -->
                <rect x="391" y="170" width="16" height="58" rx="2" fill="#404858"/>
                <rect x="391" y="170" width="3" height="58" fill="#323844"/>
                <rect x="395" y="182" width="8" height="1" rx="1" fill="rgba(180,200,220,0.4)"/>
                <rect x="395" y="187" width="5" height="1" rx="1" fill="rgba(180,200,220,0.25)"/>

                <!-- B14 - chocolate tall -->
                <rect x="409" y="160" width="20" height="68" rx="2" fill="#40200c"/>
                <rect x="409" y="160" width="4" height="68" fill="#301808"/>
                <!-- decorative panel -->
                <rect x="414" y="172" width="11" height="30" rx="1" fill="none" stroke="rgba(201,168,76,0.3)" stroke-width="0.8"/>
                <rect x="416" y="175" width="7" height="1" rx="1" fill="rgba(201,168,76,0.4)"/>
                <rect x="416" y="178" width="5" height="1" rx="1" fill="rgba(201,168,76,0.3)"/>
                <rect x="416" y="181" width="6" height="1" rx="1" fill="rgba(201,168,76,0.3)"/>
                <circle cx="419" cy="195" r="4" fill="none" stroke="rgba(201,168,76,0.35)" stroke-width="0.8"/>

                <!-- B15 - cobalt tall -->
                <rect x="431" y="158" width="18" height="70" rx="2" fill="#1c2a6a"/>
                <rect x="431" y="158" width="3.5" height="70" fill="#141f52"/>
                <rect x="436" y="170" width="9" height="1.5" rx="1" fill="rgba(140,170,255,0.5)"/>
                <rect x="436" y="176" width="6" height="1" rx="1" fill="rgba(140,170,255,0.3)"/>
                <rect x="436" y="181" width="8" height="1" rx="1" fill="rgba(140,170,255,0.3)"/>
                <circle cx="440" cy="210" r="5" fill="none" stroke="rgba(140,170,255,0.3)" stroke-width="1"/>

                <!-- ══ FLOATING BOOKS ══ -->
                <!-- Floating book 1 - top right area -->
                <g class="float-book fb1">
                    <rect x="370" y="5" width="40" height="28" rx="3" fill="#5c1c1c" transform="rotate(-12, 390, 19)"/>
                    <rect x="370" y="5" width="5" height="28" rx="2" fill="#471515" transform="rotate(-12, 390, 19)"/>
                    <rect x="377" y="10" width="25" height="1.5" rx="1" fill="rgba(255,200,150,0.5)" transform="rotate(-12, 390, 19)"/>
                    <rect x="377" y="14" width="18" height="1" rx="1" fill="rgba(255,200,150,0.3)" transform="rotate(-12, 390, 19)"/>
                    <!-- open pages suggestion -->
                    <path d="M390,20 Q400,15 405,20 Q400,25 390,20" fill="rgba(245,240,232,0.15)" transform="rotate(-12, 390, 19)"/>
                </g>

                <!-- Floating book 2 - open book top center -->
                <g class="float-book fb2">
                    <path d="M185,8 Q200,4 215,8 L215,22 Q200,18 185,22 Z" fill="#1a2a4a" opacity="0.95"/>
                    <path d="M185,8 Q170,4 155,8 L155,22 Q170,18 185,22 Z" fill="#1f3d1f" opacity="0.95"/>
                    <!-- page lines left -->
                    <line x1="161" y1="12" x2="183" y2="11" stroke="rgba(245,240,232,0.2)" stroke-width="0.8"/>
                    <line x1="162" y1="15" x2="183" y2="14" stroke="rgba(245,240,232,0.15)" stroke-width="0.7"/>
                    <line x1="163" y1="18" x2="183" y2="17" stroke="rgba(245,240,232,0.15)" stroke-width="0.7"/>
                    <!-- page lines right -->
                    <line x1="187" y1="11" x2="209" y2="12" stroke="rgba(245,240,232,0.2)" stroke-width="0.8"/>
                    <line x1="187" y1="14" x2="209" y2="15" stroke="rgba(245,240,232,0.15)" stroke-width="0.7"/>
                    <line x1="187" y1="17" x2="209" y2="18" stroke="rgba(245,240,232,0.15)" stroke-width="0.7"/>
                    <!-- spine -->
                    <line x1="185" y1="7" x2="185" y2="23" stroke="rgba(201,168,76,0.4)" stroke-width="1"/>
                </g>

                <!-- ══ FLOOR / BASE SHADOW ══ -->
                <ellipse cx="240" cy="242" rx="220" ry="6" fill="rgba(0,0,0,0.25)"/>

                <!-- ══ AMBIENT LIGHT RAYS ══ -->
                <defs>
                    <radialGradient id="ceilLight" cx="50%" cy="0%" r="60%">
                        <stop offset="0%" stop-color="rgba(201,168,76,0.08)"/>
                        <stop offset="100%" stop-color="rgba(201,168,76,0)"/>
                    </radialGradient>
                </defs>
                <ellipse cx="240" cy="0" rx="300" ry="200" fill="url(#ceilLight)"/>
            </svg>
        </div>

        <div class="brand-inner">
            <div class="brand-logo-wrap">
                <i class="bi bi-book-half brand-logo-icon"></i>
            </div>
            <h1 class="brand-name">The Book<br><em>Cellar</em></h1>
            <p class="brand-tagline">Where every page turns into a new discovery. Sign in to manage your collection.</p>
            <div class="brand-rule"></div>
            <div class="brand-features">
                <div class="brand-feature">
                    <div class="feat-icon"><i class="bi bi-bar-chart-line"></i></div>
                    <div>
                        <div class="feat-title">Real-time Dashboard</div>
                        <div class="feat-desc">Monitor inventory and sales at a glance</div>
                    </div>
                </div>
                <div class="brand-feature">
                    <div class="feat-icon"><i class="bi bi-shield-lock"></i></div>
                    <div>
                        <div class="feat-title">Role-Based Access</div>
                        <div class="feat-desc">Admin and Staff permissions built in</div>
                    </div>
                </div>
                <div class="brand-feature">
                    <div class="feat-icon"><i class="bi bi-collection"></i></div>
                    <div>
                        <div class="feat-title">Full CRUD Control</div>
                        <div class="feat-desc">Add, edit, and remove books instantly</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="brand-footer">© 2025 The Book Cellar · All rights reserved</div>
    </div>

    <!-- ── RIGHT FORM PANEL ── -->
    <div class="form-panel">
        <div class="form-inner">
            <div class="auth-card @(ViewData.ModelState.IsValid ? "" : "shake-error")">

                <div class="card-accent-line"></div>

                <div class="auth-card-header">
                    <div class="welcome-badge"><i class="bi bi-stars"></i> Welcome back</div>
                    <h2 class="auth-title">Sign in to your<br>dashboard</h2>
                    <p class="auth-sub">Enter your credentials to continue managing your store</p>
                </div>

                <form id="account" method="post" novalidate>
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div asp-validation-summary="ModelOnly" class="err-summary-box" role="alert"></div>

                    <div class="field-block">
                        <label asp-for="Input.UsernameOrEmail" class="field-label">
                            <i class="bi bi-person-circle"></i> Username or Email
                        </label>
                        <input asp-for="Input.UsernameOrEmail" class="field-input" placeholder="e.g. admin@bookcellar.com" autocomplete="username" />
                        <span asp-validation-for="Input.UsernameOrEmail" class="field-err"></span>
                    </div>

                    <div class="field-block">
                        <label asp-for="Input.Password" class="field-label">
                            <i class="bi bi-lock"></i> Password
                        </label>
                        <div class="input-wrap">
                            <input asp-for="Input.Password" class="field-input" id="pw-input" type="password" placeholder="Enter your password" autocomplete="current-password" />
                            <button type="button" class="eye-btn" onclick="togglePw('pw-input','eye1')" aria-label="Toggle password">
                                <i class="bi bi-eye" id="eye1"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="field-err"></span>
                    </div>

                    <div class="form-row-between">
                        <label class="remember-label">
                            <input asp-for="Input.RememberMe" type="checkbox" class="remember-chk" />
                            <span class="remember-text">Remember me</span>
                        </label>
                    </div>

                    <div class="button-group">
                        <button type="submit" class="btn-submit">
                            <span>Sign In</span>
                            <i class="bi bi-arrow-right"></i>
                        </button>
                        <a href="/" class="btn-back">
                            <i class="bi bi-arrow-left"></i> Back to Home
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePw(inputId, iconId) {
            const inp = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            const show = inp.type === 'password';
            inp.type = show ? 'text' : 'password';
            icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
    </script>
}

<style>
    :root {
        --gold:        #c9a84c;
        --gold-light:  #e6c97a;
        --gold-dim:    rgba(201,168,76,0.12);
        --gold-glow:   rgba(201,168,76,0.22);
        --charcoal:    #1a1c1e;
        --charcoal-2:  #2a2d31;
        --paper:       #fefcf8;
        --paper-2:     #f9f5ee;
        --text-main:   #1a1c1e;
        --text-muted:  #6b7280;
        --border:      #e5e0d6;
        --error:       #c0392b;
        --error-bg:    #fff5f5;
        --success:     #2e7d32;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { margin: 0; overflow-x: hidden; font-family: 'Jost', sans-serif; }

    /* ── SHELL ── */
    .auth-shell {
        display: flex;
        min-height: 100vh;
    }

    /* ─────────────── LEFT PANEL ─────────────── */
    .brand-panel {
        flex: 1.15;
        position: relative;
        background: var(--charcoal);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 56px 64px;
        overflow: hidden;
        color: #fff;
    }

    /* Blooming radial glows */
    .bloom-bg { position: absolute; inset: 0; pointer-events: none; }
    .bloom {
        position: absolute;
        border-radius: 50%;
        filter: blur(72px);
    }
    .bloom-1 {
        width: 520px; height: 520px;
        top: -140px; left: -120px;
        background: radial-gradient(circle, rgba(201,168,76,0.28) 0%, transparent 70%);
        animation: bloomPulse 7s ease-in-out infinite alternate;
    }
    .bloom-2 {
        width: 400px; height: 400px;
        bottom: -80px; right: -100px;
        background: radial-gradient(circle, rgba(180,120,40,0.22) 0%, transparent 70%);
        animation: bloomPulse 9s ease-in-out infinite alternate-reverse;
    }
    .bloom-3 {
        width: 280px; height: 280px;
        top: 55%; left: 45%;
        background: radial-gradient(circle, rgba(230,201,122,0.12) 0%, transparent 70%);
        animation: bloomPulse 6s ease-in-out infinite alternate;
    }

    /* ── BOOKSHELF SCENE ── */
    .shelf-scene {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 55%;
        z-index: 1;
        pointer-events: none;
        opacity: 0.75;
    }
    .shelf-svg { width: 100%; height: 100%; }

    /* Floating book animations */
    .float-book { animation-timing-function: ease-in-out; animation-iteration-count: infinite; animation-direction: alternate; }
    .fb1 { animation: floatA 5s 0s ease-in-out infinite alternate; }
    .fb2 { animation: floatB 6.5s 1s ease-in-out infinite alternate; }

    /* ── DUST PARTICLES ── */
    .dust-particles { position: absolute; inset: 0; pointer-events: none; z-index: 2; }
    .dust {
        position: absolute;
        border-radius: 50%;
        background: rgba(201,168,76,0.55);
        animation: dustDrift linear infinite;
    }
    .d1 { width: 3px; height: 3px; left: 12%; top: 70%; animation-duration: 14s; animation-delay: 0s; }
    .d2 { width: 2px; height: 2px; left: 28%; top: 55%; animation-duration: 18s; animation-delay: -4s; }
    .d3 { width: 4px; height: 4px; left: 45%; top: 75%; animation-duration: 12s; animation-delay: -2s; opacity: 0.6; }
    .d4 { width: 2px; height: 2px; left: 60%; top: 60%; animation-duration: 16s; animation-delay: -7s; }
    .d5 { width: 3px; height: 3px; left: 75%; top: 65%; animation-duration: 20s; animation-delay: -3s; opacity: 0.5; }
    .d6 { width: 2px; height: 2px; left: 88%; top: 72%; animation-duration: 15s; animation-delay: -9s; }
    .d7 { width: 3px; height: 3px; left: 35%; top: 80%; animation-duration: 22s; animation-delay: -5s; opacity: 0.4; }
    .d8 { width: 2px; height: 2px; left: 55%; top: 50%; animation-duration: 17s; animation-delay: -11s; }

    .brand-inner { position: relative; z-index: 3; max-width: 480px; }

    .brand-logo-wrap {
        width: 60px; height: 60px;
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
        border-radius: 18px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; color: var(--charcoal);
        margin-bottom: 32px;
        box-shadow: 0 8px 32px rgba(201,168,76,0.4);
        animation: fadeSlideUp 0.7s ease-out both;
    }

    .brand-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 4.2rem;
        font-weight: 700;
        line-height: 1.05;
        letter-spacing: -1px;
        color: #f5f0e8;
        animation: fadeSlideUp 0.7s 0.1s ease-out both;
    }
    .brand-name em {
        font-style: italic;
        color: var(--gold-light);
    }

    .brand-tagline {
        font-size: 1rem;
        color: rgba(245,240,232,0.65);
        line-height: 1.7;
        margin-top: 18px;
        font-weight: 300;
        max-width: 360px;
        animation: fadeSlideUp 0.7s 0.2s ease-out both;
    }

    .brand-rule {
        width: 48px; height: 2px;
        background: linear-gradient(90deg, var(--gold), transparent);
        margin: 36px 0;
        animation: fadeSlideUp 0.7s 0.3s ease-out both;
    }

    .brand-features { animation: fadeSlideUp 0.7s 0.4s ease-out both; }
    .brand-feature {
        display: flex;
        align-items: flex-start;
        gap: 18px;
        margin-bottom: 26px;
    }

    .feat-icon {
        width: 46px; height: 46px; flex-shrink: 0;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(201,168,76,0.25);
        border-radius: 13px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem;
        color: var(--gold-light);
        transition: background 0.2s, border-color 0.2s;
    }
    .brand-feature:hover .feat-icon {
        background: rgba(201,168,76,0.12);
        border-color: rgba(201,168,76,0.5);
    }

    .feat-title { font-size: 0.95rem; font-weight: 600; color: #f0ebe0; margin-bottom: 3px; }
    .feat-desc  { font-size: 0.82rem; color: rgba(245,240,232,0.5); line-height: 1.5; }

    .brand-footer {
        position: relative; z-index: 1;
        font-size: 0.72rem;
        color: rgba(245,240,232,0.25);
        letter-spacing: 0.5px;
    }

    /* ─────────────── RIGHT PANEL ─────────────── */
    .form-panel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--paper);
        padding: 48px 40px;
    }

    .form-inner { width: 100%; max-width: 460px; }

    .auth-card {
        background: #ffffff;
        border-radius: 22px;
        border: 1px solid var(--border);
        box-shadow:
            0 0 0 1px rgba(255,255,255,0.8) inset,
            0 32px 64px rgba(26,28,30,0.08),
            0 8px 16px rgba(26,28,30,0.04);
        overflow: hidden;
        animation: cardReveal 0.6s cubic-bezier(0.22,1,0.36,1) both;
    }

    .card-accent-line {
        height: 4px;
        background: linear-gradient(90deg, var(--gold) 0%, var(--gold-light) 50%, transparent 100%);
    }

    .auth-card-header { padding: 36px 40px 28px; }

    .welcome-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--gold-dim);
        border: 1px solid rgba(201,168,76,0.3);
        color: #8a6520;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 5px 12px;
        border-radius: 20px;
        margin-bottom: 16px;
    }

    .auth-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1.1;
        letter-spacing: -0.5px;
        margin-bottom: 10px;
    }

    .auth-sub {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    form { padding: 0 40px 36px; }

    /* ── FIELDS ── */
    .field-block { margin-bottom: 22px; }

    .field-label {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .field-label i { color: var(--gold); }

    .input-wrap { position: relative; }

    .field-input {
        width: 100%;
        padding: 14px 18px;
        border: 1.5px solid var(--border);
        background: var(--paper);
        border-radius: 12px;
        font-family: 'Jost', sans-serif;
        font-size: 0.93rem;
        color: var(--text-main);
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        box-sizing: border-box;
    }
    .field-input::placeholder { color: #bdb4a8; }
    .field-input:focus {
        outline: none;
        border-color: var(--gold);
        background: #fffdf7;
        box-shadow: 0 0 0 4px var(--gold-dim);
    }

    .input-wrap .field-input { padding-right: 52px; }

    .eye-btn {
    position: absolute;
    right: 14px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    color: #bdb4a8 !important;
    cursor: pointer;
    font-size: 1rem; padding: 4px;
    transition: color 0.15s;
    }
    .eye-btn i { color: inherit !important; }
    .eye-btn:hover,
    .eye-btn:hover i { color: var(--gold) !important; }

    input::-ms-reveal,
    input::-ms-clear {
        display: none;
    }

    input[type="password"]::-webkit-credentials-auto-fill-button,
    input[type="text"]::-webkit-credentials-auto-fill-button {
        display: none;
    }
    /* ── ERRORS ── */
    .err-summary-box:not(:empty) {
        background: var(--error-bg);
        border: 1px solid rgba(192,57,43,0.2);
        border-left: 3px solid var(--error);
        padding: 14px 16px;
        border-radius: 10px;
        margin-bottom: 22px;
    }
    .err-summary-box ul { list-style: none; padding: 0; margin: 0; }
    .err-summary-box li {
        color: var(--error);
        font-size: 0.85rem;
        display: flex; align-items: center; gap: 8px;
        padding: 2px 0;
    }
    .err-summary-box li::before { content: "\F333"; font-family: "bootstrap-icons"; }
    .field-err { color: var(--error); font-size: 0.78rem; margin-top: 6px; display: block; }

    /* ── REMEMBER / FORGOT ── */
    .form-row-between {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
    }

    .remember-label {
        display: flex; align-items: center; gap: 8px;
        cursor: pointer;
    }
    .remember-chk {
        width: 16px; height: 16px;
        accent-color: var(--gold);
        cursor: pointer;
    }
    .remember-text { font-size: 0.85rem; color: var(--text-muted); }

    .forgot-link {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--gold);
        text-decoration: none;
        transition: opacity 0.2s;
    }
    .forgot-link:hover { opacity: 0.75; text-decoration: underline; }

    /* ── BUTTONS ── */
    .button-group { display: flex; flex-direction: column; gap: 14px; }

    .btn-submit {
        width: 100%;
        padding: 16px 24px;
        background: linear-gradient(135deg, var(--charcoal) 0%, var(--charcoal-2) 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-family: 'Jost', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center; gap: 10px;
        letter-spacing: 0.3px;
        transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
        box-shadow: 0 4px 16px rgba(26,28,30,0.18);
        position: relative; overflow: hidden;
    }
    .btn-submit::after {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(135deg, rgba(201,168,76,0.18) 0%, transparent 60%);
        opacity: 0;
        transition: opacity 0.3s;
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,28,30,0.22); }
    .btn-submit:hover::after { opacity: 1; }
    .btn-submit:active { transform: translateY(0); }

    .btn-back {
        text-align: center;
        text-decoration: none;
        color: var(--text-muted);
        font-size: 0.87rem;
        font-weight: 500;
        display: flex; align-items: center; justify-content: center; gap: 6px;
        transition: color 0.2s;
        padding: 6px;
    }
