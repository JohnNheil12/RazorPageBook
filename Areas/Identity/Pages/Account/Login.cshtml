@page
@model RazorPageBooks.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="login-wrapper">
    <div class="modern-card">
        <form id="account" method="post">
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="text-center">
                <h1 class="card-title">@ViewData["Title"]</h1>
                <p class="card-subtitle">Use your credentials to access your account</p>
            </div>

            <hr class="divider" />

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-group">
                <label asp-for="Input.UsernameOrEmail" class="custom-label">Username or Email</label>
                <input asp-for="Input.UsernameOrEmail" class="custom-input" placeholder="johndoe123" required />
                <span asp-validation-for="Input.UsernameOrEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password" class="custom-label">Password</label>
                <input asp-for="Input.Password" class="custom-input" type="password" placeholder="••••••••" required />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="checkbox-group">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
            </div>

            <button id="login-submit" type="submit" class="btn-modern-primary">Log in</button>

            <div class="footer-links">
                <p class="small-text">Don't have an account? <a asp-page="./Register">Register</a></p>
                <a id="forgot-password" asp-page="./ForgotPassword" class="small-link">Forgot password?</a>
            </div>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="external-section">
                <div class="or-divider"><span>Or log in with</span></div>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="social-grid">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn-social" name="provider" value="@provider.Name">
                                @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    :root {
        --primary-color: #53c8ed;
        --primary-hover: #42b6db;
        --text-main: #2d3436;
        --text-muted: #636e72;
    }

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
        font-family: 'Segoe UI', Roboto, sans-serif;
    }

    .modern-card {
        background: #ffffff;
        border-radius: 32px;
        padding: 50px 40px;
        width: 100%;
        max-width: 440px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        text-align: left;
    }

    .text-center {
        text-align: center;
    }

    .card-title {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 4px;
    }

    .card-subtitle {
        color: var(--text-muted);
        font-size: 1rem;
        margin-bottom: 30px;
    }

    .divider {
        border: 0;
        border-top: 1px solid #f0f0f0;
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 22px;
    }

    .custom-label {
        display: block;
        font-weight: 700;
        font-size: 0.85rem;
        margin-bottom: 10px;
        color: #444;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .custom-input {
        width: 100%;
        padding: 14px 18px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        background-color: #fff;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

        .custom-input:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(83, 200, 237, 0.1);
        }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 25px;
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    .btn-modern-primary {
        width: 100%;
        background-color: var(--primary-color);
        color: white;
        border: none;
        padding: 16px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-bottom: 20px;
    }

        .btn-modern-primary:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(83, 200, 237, 0.3);
        }

    .or-divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 20px 0;
        color: #cbd5e0;
        font-size: 0.85rem;
    }

        .or-divider::before, .or-divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #edf2f7;
        }

        .or-divider span {
            padding: 0 10px;
        }

    .footer-links {
        text-align: center;
        margin-top: 10px;
    }

    .small-text {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin-bottom: 10px;
    }

    .footer-links a {
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 600;
    }

    .small-link {
        font-size: 0.9rem;
        display: inline-block;
        margin-top: 5px;
        opacity: 0.8;
    }
</style>
