@page
@model RazorPageBooks.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="split-container">
    <div class="brand-side">
        <div class="brand-content">
            <div class="brand-badge">
                <i class="bi bi-book-half"></i>
            </div>
            <h1 class="brand-title">The Book Cellar</h1>
            <p class="brand-tagline">Where every page turns into a new discovery. Log in to manage your collection.</p>
        </div>
    </div>

    <div class="form-side">
        <div class="modern-card">
            <form id="account" method="post">
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="form-header">
                    <h2 class="card-title">Welcome Back</h2>
                    <p class="card-subtitle">Please enter your details to continue</p>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-group">
                    <label asp-for="Input.UsernameOrEmail" class="custom-label">Username or Email</label>
                    <input asp-for="Input.UsernameOrEmail" class="custom-input" placeholder="e.g. username" required />
                    <span asp-validation-for="Input.UsernameOrEmail" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Password" class="custom-label">Password</label>
                    <input asp-for="Input.Password" class="custom-input" type="password" placeholder="••••••••" required />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-options">
                    <div class="checkbox-group">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="forgot-link">Forgot password?</a>
                </div>

                <button id="login-submit" type="submit" class="btn-modern-primary">Log In</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    :root {
        --brand-dark: #111111;
        --text-main: #1a1a1a;
        --text-muted: #718096;
        --input-bg: #f8fafc;
    }

    .split-container {
        display: flex;
        min-height: 100vh;
        width: 100%;
        background-color: #fff;
    }

    /* ── Left Side (Brand Image) ── */
    .brand-side {
        flex: 1.2;
        /* Replace the URL below with your local image path, e.g., /images/library.jpg */
        background-image: url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=2000&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px;
        overflow: hidden;
        color: white;
    }

    /* Darker overlay to make white text pop against the image */
    .brand-side::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(135deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 100%);
        z-index: 1;
    }

    .brand-content {
        position: relative;
        z-index: 10;
        max-width: 440px;
        text-align: left;
    }

    .brand-badge {
        width: 64px;
        height: 64px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        margin-bottom: 30px;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .brand-title {
        font-family: 'Playfair Display', serif;
        font-size: 4rem;
        font-weight: 700;
        margin-bottom: 20px;
        line-height: 1.1;
        text-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

    .brand-tagline {
        font-size: 1.2rem;
        line-height: 1.6;
        opacity: 0.9;
        font-weight: 300;
    }

    /* ── Right Side (Form) ── */
    .form-side {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
        background-color: #fff;
    }

    .modern-card {
        width: 100%;
        max-width: 420px;
    }

    .form-header { margin-bottom: 40px; }

    .card-title {
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--text-main);
        letter-spacing: -0.5px;
        margin-bottom: 8px;
    }

    .card-subtitle {
        color: var(--text-muted);
        font-size: 1rem;
    }

    .form-group { margin-bottom: 24px; }

    .custom-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-main);
        margin-bottom: 8px;
    }

    .custom-input {
        width: 100%;
        padding: 16px;
        border: 1.5px solid #edf2f7;
        background: var(--input-bg);
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.2s ease;
    }

    .custom-input:focus {
        outline: none;
        background: #fff;
        border-color: var(--brand-dark);
        box-shadow: 0 0 0 4px rgba(0,0,0,0.05);
    }

    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        font-size: 0.9rem;
    }

    .forgot-link {
        color: var(--text-main);
        text-decoration: none;
        font-weight: 600;
    }

    .btn-modern-primary {
        width: 100%;
        padding: 16px;
        background: var(--brand-dark);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
    }

    .btn-modern-primary:hover {
        background: #333;
        transform: translateY(-2px);
    }

    @@media (max-width: 992px) {
        .brand-side { display: none; }
        .form-side { padding: 20px; }
        .modern-card {
            background: #fff;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        }
    }
</style>